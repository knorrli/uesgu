<% content_for :title, t('.title') %>
<div class="flex flex-col gap-large">
  <%= render 'admin/back' %>
  <h1><%= t('.title') %> <span class="muted"><%= @events.total_count %></span></h1>

  <div class="flex gap-small wrap align-baseline catalogue-filters">
    <% %w[all visible hidden cancelled discarded duplicates dismissed].each do |status| %>
      <%= link_to t(".status_#{status}"),
            admin_events_path(status: (status == 'all' ? nil : status), q: params[:q].presence, sort: params[:sort].presence),
            class: class_names(:tag, active: @status == status) %>
    <% end %>
  </div>

  <%= form_with url: admin_events_path, method: :get, data: { turbo_frame: '_top' } do %>
    <%= hidden_field_tag :status, params[:status] if params[:status].present? %>
    <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
    <div class="input-wrapper flex">
      <%= text_field_tag :q, params[:q], placeholder: t('.search'), autocomplete: 'off' %>
    </div>
  <% end %>

  <div class="flex gap-small align-baseline muted catalogue-sort">
    <span><%= t('.sort_by') %></span>
    <% %w[date title].each do |sort| %>
      <%= link_to t(".sort_#{sort}"),
            admin_events_path(status: params[:status].presence, q: params[:q].presence, sort: sort),
            class: class_names('catalogue-sort-option', active: @sort == sort) %>
    <% end %>
  </div>

  <% if @events.any? %>
    <div class="event-rows">
      <% @events.each do |event| %>
        <%# A fixed date column + a stacked content block (title, then a muted
            meta line) so each event reads as one clear unit — instead of one
            wrapping line where a long title spills the venue/genres onto the next
            row and blurs which info belongs to which event. Genres/badges are
            borderless info text (a box would read as clickable). %>
        <div class="event-row">
          <span class="muted event-row__date"><%= l(event.start_date) %></span>
          <div class="event-row__main">
            <%= link_to event.title, admin_event_path(event), class: 'event-row__title' %>
            <div class="event-row__meta">
              <% if event.venue %><span><%= event.venue.name %></span><% end %>
              <% event.genres.each do |genre| %><span><%= genre.name %></span><% end %>
              <% if event.cancelled? %><span class="event-row__flag-warn"><%= t('.cancelled_badge') %></span><% end %>
              <% if event.hidden? %><span><%= t('.hidden_badge') %></span><% end %>
              <% if event.discarded? %><span><%= t('.discarded_badge', pattern: event.discarded_by_rule&.pattern) %></span><% end %>
              <% if event.overridden_fields.any? %><span><%= t('.overridden_badge') %></span><% end %>
              <%# Duplicate of a canonical (only ever shown under the duplicates filter) — link through to the event it merged into. %>
              <% if event.canonical_event %><span><%= link_to t('.duplicate_of', title: event.canonical_event.title), admin_event_path(event.canonical_event) %></span><% end %>
              <%# Canonical that aggregates N merged sources — manage the merge on its show page. %>
              <% if (merged = @duplicate_counts[event.id].to_i).positive? %><span><%= t('.merged_badge', count: merged) %></span><% end %>
            </div>
          </div>
          <% if event.dismissed? %>
            <%= button_to t('.restore'), undismiss_admin_event_path(event), method: :patch, class: 'button-small' %>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="flex justify-center"><%= paginate @events %></div>
  <% else %>
    <p class="muted"><%= t('.empty') %></p>
  <% end %>
</div>
