<% content_for :title, @event.title %>
<div class="flex flex-col gap-large">
  <%= render layout: "shared/page_header", locals: { back_path: admin_events_path, back_label: t("admin.events.show.back") } do %>
    <h1><%= @event.title %></h1>
    <div class="flex gap-small wrap align-baseline muted">
      <span><%= l(@event.start_date) %></span>
      <% if @event.venue %><span><%= @event.venue.name %></span><% end %>
      <%= link_to t('admin.events.show.source_link'), @event.url, target: '_blank', rel: 'noopener' %>
      <% if @event.data_source.present? %><span><%= t('admin.events.show.source_label', source: @event.data_source) %></span><% end %>
      <% if @event.cancelled? %><span class="chip"><%= t('admin.events.index.cancelled_badge') %></span><% end %>
      <% if @event.hidden? %><span><%= t('admin.events.index.hidden_badge') %></span><% end %>
      <% if @event.dismissed? %><span class="chip"><%= t('admin.events.show.dismissed_badge') %></span><% end %>
    </div>
  <% end %>

  <%# Editing any field here locks it against the next re-scrape; the
      hidden/cancelled flags stay read-only (they re-derive from the genres). %>
  <p class="muted"><%= t('.intro') %></p>

  <%= form_with model: @event, url: admin_event_path(@event), method: :patch, class: 'account-form flex flex-col gap-medium' do |f| %>
    <label class="flex flex-col gap-small">
      <span class="flex gap-small align-baseline">
        <%= t('.title_label') %>
        <% if @event.overridden?(:title) %><span class="chip"><%= t('.overridden_badge') %></span><% end %>
      </span>
      <%= text_field_tag 'event[title]', @event.title, autocomplete: 'off' %>
    </label>

    <label class="flex flex-col gap-small">
      <span class="flex gap-small align-baseline">
        <%= t('.description_label') %>
        <% if @event.overridden?(:description) %><span class="chip"><%= t('.overridden_badge') %></span><% end %>
      </span>
      <%= text_field_tag 'event[description]', @event.description, autocomplete: 'off' %>
    </label>

    <div class="flex gap-medium wrap">
      <label class="flex flex-col gap-small">
        <span class="flex gap-small align-baseline">
          <%= t('.date_label') %>
          <% if @event.overridden?(:start_date) || @event.overridden?(:start_time) %>
            <span class="chip"><%= t('.overridden_badge') %></span>
          <% end %>
        </span>
        <%= date_field_tag 'event[date]', @event.start_date&.iso8601 %>
      </label>
      <label class="flex flex-col gap-small">
        <span><%= t('.time_label') %></span>
        <%= time_field_tag 'event[time]', @event.start_time&.strftime('%H:%M') %>
      </label>
    </div>

    <label class="flex flex-col gap-small">
      <span class="flex gap-small align-baseline">
        <%= t('.genres_label') %>
        <% if @event.overridden?(:genres) %><span class="chip"><%= t('.overridden_badge') %></span><% end %>
      </span>
      <div class="input-wrapper flex genre-combobox">
        <%# Multiselect over the assignable taxonomy; submits comma-joined Genre
            ids the controller maps back to names. Options come from the shared
            genre_combobox_options helper, so the umbrella genres sort to the top
            and carry their descendant count — same surfacing as the genre editor. %>
        <%= f.combobox :override_genre_ids, genre_combobox_options(Genre.listable),
              value: @event.override_genre_ids.join(','),
              multiselect_chip_src: chips_genres_path,
              placeholder: t('.genres_label') do |combobox| %>
          <% combobox.customize_fieldset class: 'flex-grow' %>
          <% combobox.customize_input class: 'flex-grow' %>
        <% end %>
      </div>
      <span class="muted"><%= t('.genres_hint') %></span>
    </label>

    <%= submit_tag t('.save') %>
  <% end %>

  <% locked = @event.overridden_fields & Event::LOCKABLE_FIELDS %>
  <% if locked.any? %>
    <section class="flex flex-col gap-small">
      <h2><%= t('.overrides_heading') %></h2>
      <p class="muted"><%= t('.overrides_intro') %></p>
      <ul class="admin-list">
        <%# Date and time release together, so show them as a single "schedule" row. %>
        <% rows = locked.include?('start_date') || locked.include?('start_time') ? (locked - %w[start_date start_time]) + ['start_date'] : locked %>
        <% rows.each do |field| %>
          <li class="admin-row">
            <span class="admin-row__main"><%= t(".field_#{field}") %></span>
            <%= button_to t('.revert'), revert_admin_event_path(@event, field: field),
                  method: :patch, class: 'button-small' %>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <section class="flex flex-col gap-small">
    <h2><%= t('.dedup_heading') %></h2>
    <% if @event.canonical_event %>
      <p class="muted">
        <%= t('.is_duplicate_html',
              link: link_to(@event.canonical_event.title, admin_event_path(@event.canonical_event))) %>
      </p>
      <%= button_to t('.unmerge'), unmerge_admin_event_path(@event), method: :patch, class: 'button-small' %>
    <% else %>
      <% if @event.duplicate_events.any? %>
        <p class="muted"><%= t('.has_duplicates') %></p>
        <ul class="admin-list">
          <% @event.duplicate_events.includes(:locations).each do |dup| %>
            <li class="admin-row">
              <span class="admin-row__main">
                <%= link_to dup.title, admin_event_path(dup) %>
                <span class="muted">(<%= dup.data_source %>)</span>
              </span>
            </li>
          <% end %>
        </ul>
      <% end %>
      <p class="muted"><%= t('.merge_intro') %></p>
      <%= form_with url: merge_admin_event_path(@event), method: :patch, class: 'flex gap-small align-baseline wrap' do %>
        <%# Title autocomplete over kept canonical events (admin/events#search),
            emitting the chosen event's id into canonical_id — no more hunting for
            a raw database id. %>
        <div class="input-wrapper flex flex-grow merge-combobox">
          <%= combobox_tag :canonical_id, search_admin_events_path(exclude: @event.id),
                placeholder: t('.merge_placeholder'), autocomplete: 'off' do |combobox| %>
            <% combobox.customize_fieldset class: 'flex-grow' %>
            <% combobox.customize_input class: 'flex-grow' %>
          <% end %>
        </div>
        <%= submit_tag t('.merge'), class: 'button-small' %>
      <% end %>
    <% end %>
  </section>

  <section class="flex flex-col gap-small">
    <h2><%= t('.dismiss_heading') %></h2>
    <% if @event.dismissed? %>
      <p class="muted"><%= t('.dismissed_intro') %></p>
      <%= button_to t('.restore'), undismiss_admin_event_path(@event), method: :patch, class: 'button-small' %>
    <% else %>
      <p class="muted"><%= t('.dismiss_intro') %></p>
      <%= button_to t('.dismiss'), admin_event_path(@event), method: :delete, class: 'button-small danger' %>
    <% end %>
  </section>
</div>
