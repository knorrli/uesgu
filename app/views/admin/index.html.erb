<div class="flex flex-col gap-large">
  <h1><%= t('.title') %></h1>

  <dl class="flex flex-col gap-small">
    <div class="stat">
      <dt><%= Event.model_name.human(count: :many) %></dt>
      <span class="stat__leader"></span>
      <dd class="muted"><%= Event.count %></dd>
    </div>
    <div class="stat">
      <dt><%= Style.model_name.human(count: :many) %></dt>
      <span class="stat__leader"></span>
      <dd class="muted"><%= Style.count %></dd>
    </div>
    <div class="stat">
      <dt><%= Location.model_name.human(count: :many) %></dt>
      <span class="stat__leader"></span>
      <dd class="muted"><%= @event_tag_stats.location_tags.count %></dd>
    </div>
  </dl>

  <section class="flex flex-col gap-small">
    <h2><%= Genre.model_name.human(count: :many) %> <span class="muted"><%= @event_tag_stats.genre_tags.count %></span></h2>
    <dl class="flex flex-col gap-small">
      <div class="stat">
        <dt><%= t('.assigned') %></dt>
        <span class="stat__leader"></span>
        <dd class="muted"><%= @event_tag_stats.assigned_genre_tags.count %></dd>
      </div>
      <div class="stat">
        <dt><%= t('.unassigned') %></dt>
        <span class="stat__leader"></span>
        <dd class="muted"><%= @event_tag_stats.unassigned_genre_tags.count %></dd>
      </div>
      <div class="stat">
        <dt><%= t('.ignored') %></dt>
        <span class="stat__leader"></span>
        <dd class="muted"><%= @event_tag_stats.ignored_genre_tags.count %></dd>
      </div>
    </dl>
    <div class="flex gap-medium wrap">
      <%= link_to t('.assign_unassigned_genres'), queue_genres_path %>
      <%= link_to t('.browse_genres'), genres_path %>
    </div>
  </section>

  <section class="flex flex-col gap-small">
    <h2><%= t('.accounts_heading') %></h2>
    <dl class="flex flex-col gap-small">
      <div class="stat">
        <dt><%= t('.users') %></dt>
        <span class="stat__leader"></span>
        <dd class="muted"><%= User.count %></dd>
      </div>
      <div class="stat">
        <dt><%= t('.open_invitations') %></dt>
        <span class="stat__leader"></span>
        <dd class="muted"><%= Invitation.available.count %></dd>
      </div>
    </dl>
    <div class="flex gap-medium wrap">
      <%= link_to t('.manage_users'), admin_users_path %>
      <%= link_to t('.manage_invitations'), admin_invitations_path %>
    </div>
  </section>
</div>
