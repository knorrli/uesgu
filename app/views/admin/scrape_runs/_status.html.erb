<%# Per-scraper status pill. nil = the scraper produced no result in this run. %>
<%# locals: (result:) %>
<% if result %>
  <span class="scrape-badge scrape-badge--<%= result.display_status %>"><%= t("admin.scrape_runs.status.#{result.display_status}") %></span>
<% else %>
  <span class="muted">—</span>
<% end %>
