<div class="flex flex-col gap-large">
  <%= render 'admin/back', path: admin_scrape_runs_path, label: t('.back') %>

  <h1 class="flex gap-small wrap">
    <%= l(@run.started_at) %>
    <%= render 'admin/scrape_runs/run_badge', run: @run %>
  </h1>
  <p class="muted">
    <%= t('admin.scrape_runs.index.tally', total: @run.scrapers_total, ok: @run.scrapers_ok,
                                           empty: @run.scrapers_empty, failed: @run.scrapers_failed) %>
    <% if @run.duration %> · <%= t('admin.scrape_runs.index.took', seconds: @run.duration.round) %><% end %>
  </p>

  <div class="scrape-table-wrap">
    <table class="scrape-table">
      <thead>
        <tr>
          <th><%= t('admin.scrape_runs.index.col.scraper') %></th>
          <th><%= t('admin.scrape_runs.index.col.status') %></th>
          <th class="num"><%= t('admin.scrape_runs.index.col.seen') %></th>
          <th class="num"><%= t('admin.scrape_runs.index.col.new') %></th>
          <th class="num"><%= t('admin.scrape_runs.index.col.updated') %></th>
          <th class="num"><%= t('admin.scrape_runs.index.col.skipped') %></th>
          <th class="num"><%= t('.duration') %></th>
        </tr>
      </thead>
      <tbody>
        <% @results.each do |result| %>
          <tr>
            <td><%= result.scraper %></td>
            <td><%= render 'admin/scrape_runs/status', result: result %></td>
            <td class="num"><%= result.rows_seen %></td>
            <td class="num"><%= result.created_count %></td>
            <td class="num"><%= result.updated_count %></td>
            <td class="num"><%= result.skipped_count %></td>
            <td class="num"><%= number_with_precision(result.duration_ms.to_i / 1000.0, precision: 1) %>s</td>
          </tr>
          <% if result.failed? && result.error_message.present? %>
            <tr>
              <td colspan="7" class="scrape-error"><%= result.error_class %>: <%= result.error_message %></td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>

  <section class="flex flex-col gap-small">
    <h2><%= t('.created_events') %> <span class="muted"><%= @created_events.size %></span></h2>
    <% if @created_events.any? %>
      <ul class="admin-list">
        <% @created_events.each do |event| %>
          <li class="admin-row">
            <span class="admin-row__main">
              <%= link_to event.title, event.url, target: '_blank', rel: 'noopener' %>
            </span>
            <span class="stat__leader"></span>
            <span class="admin-row__meta muted">
              <%= l(event.start_date) %><% if event.venue %> · <%= event.venue.name %><% end %>
            </span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="muted"><%= t('.no_created_events') %></p>
    <% end %>
  </section>
</div>
