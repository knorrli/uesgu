<% content_for :title, t('.title') %>
<div class="flex flex-col gap-large">
  <%# Absolute i18n keys inside the page_header block: lazy `.keys` would resolve
      against shared.page_header.* (see project memory). %>
  <%= render layout: "shared/page_header", locals: { back_path: admin_path, back_label: t("admin.back") } do %>
    <h1><%= t('admin.scraper_coverage.index.title') %></h1>
  <% end %>

  <p class="muted"><%= t('.intro') %></p>

  <% if @presenter.any? %>
    <div class="scrape-table-wrap">
      <table class="scrape-table">
        <thead>
          <tr>
            <th><%= t('.col.scraper') %></th>
            <th class="num"><%= t('.col.events') %></th>
            <th class="num"><%= t('.col.time') %></th>
            <th class="num"><%= t('.col.subtitle') %></th>
            <th class="num"><%= t('.col.genres') %></th>
            <th class="num"><%= t('.col.distinct_genres') %></th>
          </tr>
        </thead>
        <tbody>
          <% @presenter.rows.each do |row| %>
            <tr class="<%= 'is-empty' unless row.present? %>">
              <td><%= row.source.underscore %></td>
              <td class="num"><%= row.events %></td>
              <td class="num"><%= coverage_cell(row, row.time_pct) %></td>
              <td class="num"><%= coverage_cell(row, row.subtitle_pct) %></td>
              <td class="num"><%= coverage_cell(row, row.genre_pct) %></td>
              <td class="num"><%= row.distinct_genres.positive? ? row.distinct_genres : '—' %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="muted"><%= t('.empty') %></p>
  <% end %>
</div>
