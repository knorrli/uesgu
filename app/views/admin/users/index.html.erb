<% content_for :title, t('.title') %>
<div class="flex flex-col gap-large">
  <%= render layout: "shared/page_header", locals: { back_path: admin_path, back_label: t("admin.back") } do %>
    <h1><%= t('.title') %> <span class="muted"><%= @users.total_count %></span></h1>
  <% end %>

  <% if @users.any? %>
    <ul class="admin-list">
      <% @users.each do |user| %>
        <li class="admin-row">
          <span class="admin-row__main">
            <%= link_to user.username, admin_user_path(user) %>
            <% if user.admin? %><span class="chip"><%= t('admin.users.admin_badge') %></span><% end %>
          </span>
          <span class="stat__leader"></span>
          <span class="admin-row__meta muted"><%= l(user.created_at.to_date) %></span>
        </li>
      <% end %>
    </ul>

    <%= paginate @users %>
  <% else %>
    <p class="muted"><%= t('.empty') %></p>
  <% end %>
</div>
