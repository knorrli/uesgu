<% list_params = request.query_parameters.except('view', 'start_date', 'page', 'd') %>
<section id="calendar" class="event-calendar flex flex-col gap-medium" data-controller="calendar">
  <%= month_calendar(start_date: @calendar_start, events: events, attribute: :start_date) do |date, day_events| %>
    <% number = class_names('calendar-day-number', today: date == Date.current) %>
    <% if day_events.any? %>
      <%# Transparent overlay fills the cell's full (row) height so the whole cell
          is clickable; the in-flow .day-content below sizes the cell so it grows. %>
      <%= link_to '', day_events_path(list_params.merge('date' => date.iso8601)),
            class: 'calendar-day-link', 'aria-label': l(date, format: :detailed),
            data: { action: 'calendar#select', turbo_frame: 'day-detail' } %>
    <% end %>
    <div class="day-content">
      <div class="<%= number %>"><%= date.day %></div>
      <% day_events.each do |event| %>
        <div class="event">
          <% if event.venue %><span class="event-venue"><%= event.venue.name %></span> <% end %><span class="event-title"><%= event.title %></span>
        </div>
      <% end %>
    </div>
  <% end %>

  <%= turbo_frame_tag 'day-detail' do %>
    <p class="day-detail-prompt muted"><%= t('events.day.prompt') %></p>
  <% end %>
</section>
