<%# Saved-show bookmarks are surfaced on the main programme; on the saved-shows
    calendar every event is saved by definition, so the marker is suppressed
    there (it would flag every day). %>
<% show_saved_markers = local_assigns.fetch(:show_saved_markers, true) %>
<%# The whole calendar is a Turbo Frame that advances history: clicking a day (or
    a month-nav link) reloads just this frame and updates the URL, so the open day
    is linkable and reload-safe — while the filter's combobox/datepicker, which sit
    outside the frame, are never disturbed and the page scroll stays put. The open
    day's detail row is rendered server-side inside the grid (see _month_calendar). %>
<section id="calendar" class="event-calendar flex flex-col gap-medium">
  <%= turbo_frame_tag 'calendar-frame', data: { turbo_action: 'advance' } do %>
    <%= month_calendar(start_date: @calendar_start, events: events, attribute: :start_date) do |date, day_events| %>
      <%# The date's own prominence is the "something's on, tap me" affordance:
          full weight when the day has events, muted when it has none (.empty). No
          separate count — the cell leads with relevance (markers), not a tally. %>
      <% number = class_names('calendar-day-number', today: date == Date.current, empty: day_events.none?) %>
      <% if day_events.any? %>
        <% selected = date == @open_day %>
        <%# Transparent overlay fills the cell's full (row) height so the whole cell
            is clickable; the in-flow .day-content below sizes the cell so it grows.
            A second click on the open day navigates back to the collapsed URL. %>
        <%= link_to '', selected ? calendar_collapse_path : calendar_day_path(date),
              class: class_names('calendar-day-link', selected: selected),
              'aria-label': l(date, format: :detailed) %>
      <% end %>
      <% if day_events.any? && show_saved_markers %>
        <% saved_count = day_events.count { |event| event_saved?(event) } %>
        <%# Cell relevance markers, top-right: a raspberry HEART when you've saved a
            show that day, and a quieter amber DOT when a show matches one of your
            saved filters (interest). Heart leads (strong, rare); the dot follows. %>
        <% interest = day_events.any? { |event| interest_event?(event) } %>
        <% if saved_count.positive? || interest %>
          <div class="day-markers" aria-hidden="true">
            <% if saved_count.positive? %><span class="day-saved-marker"><% if saved_count > 1 %><span class="day-saved-count"><%= saved_count %></span><% end %></span><% end %>
            <% if interest %><span class="day-interest-marker"></span><% end %>
          </div>
        <% end %>
      <% end %>
      <div class="day-content">
        <div class="<%= number %>"><%= date.day %></div>
        <%# Desktop-only relevance headline: up to two venues of the day's saved
            shows, with any remainder spilled into a "+N more" line. Hidden on mobile
            (no room — the marker carries the signal there). Only on relevant days. %>
        <% if day_events.any? && (headline = calendar_day_headline(day_events)) %>
          <% headline.venues.each do |venue| %>
            <span class="day-headline"><%= venue %></span>
          <% end %>
          <% if headline.extra.positive? %>
            <span class="day-headline-more"><%= t("simple_calendar.more_venues", count: headline.extra) %></span>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% end %>
</section>
