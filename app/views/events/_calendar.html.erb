<% followed_keys = favorite_followed_keys.to_set %>
<%# The whole calendar is a Turbo Frame that advances history: clicking a day (or
    a month-nav link) reloads just this frame and updates the URL, so the open day
    is linkable and reload-safe — while the filter's combobox/datepicker, which sit
    outside the frame, are never disturbed and the page scroll stays put. The open
    day's detail row is rendered server-side inside the grid (see _month_calendar). %>
<section id="calendar" class="event-calendar flex flex-col gap-medium">
  <%= turbo_frame_tag 'calendar-frame', data: { turbo_action: 'advance' } do %>
    <%= month_calendar(start_date: @calendar_start, events: events, attribute: :start_date) do |date, day_events| %>
      <% number = class_names('calendar-day-number', today: date == Date.current) %>
      <% if day_events.any? %>
        <% selected = date == @open_day %>
        <%# Transparent overlay fills the cell's full (row) height so the whole cell
            is clickable; the in-flow .day-content below sizes the cell so it grows.
            A second click on the open day navigates back to the collapsed URL. %>
        <%= link_to '', selected ? calendar_collapse_path : calendar_day_path(date),
              class: class_names('calendar-day-link', selected: selected),
              'aria-label': l(date, format: :detailed) %>
      <% end %>
      <% if day_events.any? %>
        <% day_keys = calendar_day_favorite_keys(day_events) %>
        <span class="day-favorite-marker" aria-hidden="true" data-day-keys="<%= day_keys.to_json %>"
              <%= 'hidden' unless day_keys.any? { |key| followed_keys.include?(key) } %>>&#9829;</span>
      <% end %>
      <div class="day-content">
        <div class="<%= number %>"><%= date.day %></div>
        <% if day_events.any? %>
          <% venues = calendar_day_venues(day_events, favorites: @favorites) %>
          <%# Wide screens: a glanceable, deduped venue summary (full detail on tap). %>
          <ul class="day-venues">
            <% venues.first(4).each do |venue| %>
              <li class="day-venue">
                <span class="day-venue-name"><%= venue.name %></span><% if venue.count > 1 %> <span class="day-venue-count">×<%= venue.count %></span><% end %>
              </li>
            <% end %>
            <% if venues.size > 4 %>
              <li class="day-venue more"><%= t('events.calendar.more', count: venues.size - 4) %></li>
            <% end %>
          </ul>
          <%# Narrow screens: just a count — columns are too narrow for text. %>
          <span class="day-count" aria-hidden="true"><%= day_events.size %></span>
        <% end %>
      </div>
    <% end %>
  <% end %>
</section>
