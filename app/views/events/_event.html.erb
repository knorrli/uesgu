<% interactive = local_assigns.fetch(:interactive, true) %>
<article id="<%= dom_id event %>" class="<%= class_names(:event, past: event.start_date < Date.current.beginning_of_day, cancelled: event.cancelled?) %>">
  <div class="event-body">

    <h3 class="event-title">
      <% if event.start_time.present? %><span class="event-time"><%= l event.start_time, format: :time %></span> <% end %><% if event.cancelled? %><span class="event-cancelled"><%= t('events.cancelled') %></span> <% end %><%= link_to event.url, target: '_blank', rel: 'noopener' do %><%= event.title %> <span class="event-link-marker" aria-hidden="true">&#8599;</span><% end %>
    </h3>

    <% if event.subtitle.present? %>
      <div class="event-subtitle"><%= simple_format(event.subtitle) %></div>
    <% end %>

    <%# One descriptor row: genres + the styles a genre doesn't already reveal, all
        equal, all tapped through the same freetext path. Styles are derived from
        the genres, so we show the genres (granular, with the admin edit gear) and
        append a style ONLY when no shown genre is substring-related to it — so the
        broad bucket "Rock" surfaces on an event whose genres are "Experimental /
        Pest Modern" (the otherwise-invisible reason it matches a "rock" search),
        but the redundant "Metal" is suppressed when "Modern Metal" is already
        there, and "Electronic" when "Electro" is. That keeps search recall AND
        answers "why is this here?" without the roll-up duplication. Equal-weight
        pills, so there's no style/genre tier to ask about. %>
    <% genre_names = event.genres.map { |genre| genre.name.downcase } %>
    <% extra_styles = event.styles.reject { |style|
         name = style.name.downcase
         genre_names.any? { |genre| genre.include?(name) || name.include?(genre) }
       } %>
    <% if event.genres.any? || extra_styles.any? %>
      <div class="event-genres">
        <% first = true %>
        <% event.genres.each do |genre| %>
          <% unless first %><span class="sep" aria-hidden="true">&middot;</span><% end %><% first = false %>
          <%= event_filter_tag genre.name, field: 'q[]', value: genre.name, interactive: interactive %><% if current_user&.admin? && interactive %><%= link_to edit_tag_path(genre), data: { turbo_frame: '_top' }, class: 'icon-button meta-edit', 'aria-label': t('events.edit_tag') do %><span class="ph ph-gear"></span><% end %><% end %>
        <% end %>
        <% extra_styles.each do |style| %>
          <% unless first %><span class="sep" aria-hidden="true">&middot;</span><% end %><% first = false %>
          <%= event_filter_tag style.name, field: 'q[]', value: style.name, interactive: interactive %>
        <% end %>
      </div>
    <% end %>

  </div>

  <% if current_user %>
    <div class="event-actions">
      <%= event_save_button(event) %>
      <% if current_user.admin? && interactive %>
        <%= link_to admin_event_path(event), class: 'icon-button', data: { turbo_frame: '_top' }, 'aria-label': t('events.edit_event') do %>
          <span class="ph ph-gear"></span>
        <% end %>
        <%= button_to event, method: :delete, class: 'icon-button danger', 'aria-label': t('events.delete_event') do %>
          <span class="ph ph-trash"></span>
        <% end %>
      <% end %>
    </div>
  <% end %>
</article>
