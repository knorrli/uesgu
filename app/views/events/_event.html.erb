<%# `interactive` = this is the live end-user programme list. It governs only the
    end-user affordances: interest highlighting (below) and the filter-tag toggle /
    green semantics (event_filter_tag). It does NOT gate admin tooling — the edit
    gears and delete are orthogonal and follow admin? alone, so they're available in
    the read-only preview too (e.g. the genre-curation queue, which renders this
    card with interactive:false but where the admin still wants to jump in and fix
    a mis-tagged event). %>
<% interactive = local_assigns.fetch(:interactive, true) %>
<% rescheduled = event.rescheduled? && !event.cancelled? %>
<%# Interest = this show matches one of your saved filters (date window ignored).
    Only on the live filterable list (interactive), never the admin preview. %>
<% interest = interactive && interest_event?(event) %>
<article id="<%= dom_id event %>" class="<%= class_names(:event, past: event.start_date < Date.current.beginning_of_day, cancelled: event.cancelled?, rescheduled: rescheduled, 'is-interest': interest) %>">
  <div class="event-body">

    <h3 class="event-title">
      <% if event.start_time.present? %><span class="event-time"><%= l event.start_time, format: :time %></span> <% end %><%= link_to event.url, target: '_blank', rel: 'noopener' do %><%= event.title %> <span class="event-link-marker" aria-hidden="true">&#8599;</span><% end %><%# Trailing event-level markers (a quiet .chip sub-family, colour = severity):
          cancelled / rescheduled status, then the off-site source. All AFTER the
          title so they stay secondary to it. %><% if event.cancelled? %> <span class="chip chip--cancelled"><%= t('events.cancelled') %></span><% end %><% if rescheduled %> <span class="chip chip--moved"><%= t('events.rescheduled') %></span><% end %><% if (source = event_offsite_source(event)) %> <span class="chip chip--source" title="<%= t('events.offsite_link', source: source) %>"><%= source %></span><% end %>
    </h3>

    <% if event.description.present? %>
      <div class="event-description"><%= simple_format(event.description) %></div>
    <% end %>

    <%# One descriptor row: the event's OWN genres, each a filter tag. Tapping a
        genre filters by it AND its whole subtree (g[]) — so "Rock" catches its
        sub-genres — and a genre lights green when it sits under an applied filter
        (descendant-set membership, see EventsHelper#event_filter_tag). No derived
        styles: the tree expansion answers "why is this here?" via the lit genre,
        so the old style roll-up is gone. %>
    <% if event.genres.any? %>
      <div class="event-genres">
        <% event.genres.each_with_index do |genre, i| %>
          <% if i.positive? %><span class="sep" aria-hidden="true">&middot;</span><% end %>
          <%# Tag + (admin) edit gear are one unit so the gear rides flush against
              its own tag — the row's wrap-gap falls between genre units, not between
              a tag and its gear. %>
          <span class="event-genre"><%= event_filter_tag genre.name, field: 'g[]', value: genre.name, interactive: interactive %><% if interest && interest_why_genre?(event, genre) %><span class="interest-flag" aria-hidden="true"><i class="ph ph-flag"></i></span><% end %><% if current_user&.admin? %><%= link_to edit_tag_path(genre), data: { turbo_frame: '_top' }, class: 'icon-button meta-edit', 'aria-label': t('events.edit_tag') do %><span class="ph ph-gear"></span><% end %><% end %></span>
        <% end %>
      </div>
    <% end %>

  </div>

  <% if current_user %>
    <div class="event-actions">
      <%= event_save_button(event) %>
      <% if current_user.admin? %>
        <%= link_to admin_event_path(event), class: 'icon-button', data: { turbo_frame: '_top' }, 'aria-label': t('events.edit_event') do %>
          <span class="ph ph-gear"></span>
        <% end %>
        <%# return_to (when the card carries one, e.g. the genre-curation queue) lands
            the delete back on that page instead of the public feed. %>
        <%= button_to event, method: :delete, params: { return_to: local_assigns[:return_to] }.compact, class: 'icon-button danger', 'aria-label': t('events.delete_event') do %>
          <span class="ph ph-trash"></span>
        <% end %>
      <% end %>
    </div>
  <% end %>
</article>
