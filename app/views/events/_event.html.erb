<article id="<%= dom_id event %>" class="<%= class_names(:event, past: event.start_date < Date.current.beginning_of_day) %>">
  <div class="event-body">

    <h3 class="event-title">
      <% if event.start_time.present? %><span class="event-time"><%= l event.start_time, format: :time %></span> <% end %><%= link_to event.url, target: :blank do %><%= event.title %> <span class="event-link-marker" aria-hidden="true">&#8599;</span><% end %>
    </h3>

    <% if event.subtitle.present? %>
      <div class="event-subtitle"><%= simple_format(event.subtitle) %></div>
    <% end %>

    <% if event.styles.any? %>
      <div class="event-styles">
        <% event.styles.each_with_index do |style, i| %>
          <% if i > 0 %><span class="sep" aria-hidden="true">&middot;</span><% end %>
          <%= button_tag style.name, type: :button,
                class: class_names('filter-link', active: (filter.style_list.include?(style.name) || filter.queries.any? { |query| style.name =~ %r{.*#{query}.*}i })),
                data: { action: 'filter#toggleFilter', filter_field_name_param: 's[]', filter_value_param: style.name } %>
        <% end %>
      </div>
    <% end %>

    <% if event.genres.any? %>
      <div class="event-genres">
        <% event.genres.each_with_index do |genre, i| %>
          <% if i > 0 %><span class="sep" aria-hidden="true">&middot;</span><% end %>
          <span class="<%= class_names('genre', active: filter.queries.any? { |query| genre.name =~ %r{.*#{query}.*}i }) %>"><%= genre.name %><% if current_user&.admin? %><%= link_to edit_tag_path(genre), target: :blank, class: 'meta-edit', 'aria-label': 'Edit tag' do %><span class="ti-settings"></span><% end %><% end %></span>
        <% end %>
      </div>
    <% end %>

  </div>

  <% if current_user&.admin? %>
    <div class="event-actions">
      <%= button_to event, class: 'button event-delete', data: { turbo_method: :delete }, 'aria-label': 'Delete event' do %>
        <span class="ti-trash"></span>
      <% end %>
    </div>
  <% end %>
</article>
