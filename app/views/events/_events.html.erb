<section id="events" class="flex flex-col gap-xlarge event-list">
  <% events_by_date = @events.group_by(&:start_date) %>
  <% events_by_date.each do |date, events| %>
    <div class="flex flex-col gap-medium date-events <%= class_names(past: date < Date.current.beginning_of_day) %>"
         data-controller="day-summary" data-action="save:toggled->day-summary#adjustSaved">
      <%# Date stays flush-left; the ♥ saved count sits just after it, collapsing to
          nothing when a day has no saved shows (see .day-summary). %>
      <h2 id="<%= date.iso8601 %>" class="flex date">
        <span class="date__label"><%= l date, format: :detailed %></span>
        <%= render 'day_summary', events: events %>
      </h2>
      <%= render 'venue_groups', events: events, filter: @filter %>
    </div>
  <% end %>

  <div class="flex justify-center">
    <%= paginate @events %>
  </div>
</section>
