<%# ─────────────────────────────────────────────────────────────────────────
    Mobile filter UI: a trigger bar + three full-screen bottom sheets (What /
    Where / When). Shown only below the tablet breakpoint (see .filter-sheets in
    events.css); the inline combobox filter (_filter) takes over above it.

    It is a plain GET form whose option rows ARE the submitted inputs
    (name="s[]/q[]/l[]/d[]"), so it produces the exact same params as the inline
    filter and EventsController#build_filter needs no changes. Selections are
    staged inside a sheet and committed (one Turbo navigation) when it closes;
    server-rendered state below keeps the bar, chips and results in sync.

    Sheets own a full-screen search field instead of a floating dropdown, so the
    on-screen keyboard never collides with an options list — the field is only
    focused when the user taps it, never on open.
   ───────────────────────────────────────────────────────────────────────── %>

<% what_terms  = @filter.queries + @filter.genres %>
<% where_terms = @filter.location_list.map { |loc| location_display(loc) } %>
<% when_terms  = @filter.date_ranges.map { |range| date_range_label(range) } %>
<% custom_range = @filter.date_ranges.find { |r| r.match?(/\A\d{4}-\d{2}-\d{2} - \d{4}-\d{2}-\d{2}\z/) } %>
<% custom_start, custom_end = custom_range&.split(' - ') %>

<div class="filter-sheets"
     data-controller="filter-sheets"
     data-filter-sheets-search-for-template-value="<%= t('events.filter.search_for', query: '%{query}') %>"
     data-filter-sheets-search-anything-value="<%= t('events.filter.search_anything') %>">
  <%= form_with url: events_path, method: :get, class: 'filter-sheets__form',
        html: { autocomplete: 'off' },
        data: { filter_sheets_target: 'form', turbo_frame: '_top' } do %>

    <%# ── Trigger bar — each row opens its sheet ── %>
    <div class="filter-sheets__bar">
      <% [
           { field: 'what',  icon: 'query',     terms: what_terms,  empty: t('events.filter.what') },
           { field: 'where', icon: 'locations', terms: where_terms, empty: t('events.filter.where') },
           { field: 'when',  icon: 'date',      terms: when_terms,  empty: t('events.filter.when') },
         ].each do |trig| %>
        <button type="button" class="filter-trigger" aria-haspopup="dialog"
                data-action="filter-sheets#open" data-filter-sheets-field-param="<%= trig[:field] %>">
          <span class="filter-trigger__icon <%= tag_icon_class(context: trig[:icon]) %>"></span>
          <span class="filter-trigger__label <%= 'is-empty' if trig[:terms].empty? %>">
            <% if trig[:terms].empty? %>
              <%= trig[:empty] %>
            <% else %>
              <%= trig[:terms].first %><% if trig[:terms].size > 1 %><span class="filter-trigger__more"> +<%= trig[:terms].size - 1 %></span><% end %>
            <% end %>
          </span>
          <% if trig[:terms].any? %>
            <span class="badge"><%= trig[:terms].size %></span>
          <% end %>
          <span class="filter-trigger__chevron ph ph-caret-right"></span>
        </button>
      <% end %>
    </div>

    <%# ── Applied filters (removable). Server-rendered = always matches results.
        Chips wrap inside their own growing container; the notify bell is pinned to
        the right of the same row, so applying a filter doesn't add a separate row.
        The whole summary only renders when a filter is active. ── %>
    <% if @filter.active? %>
      <div class="filter-sheets__summary">
        <div class="filter-sheets__summary-chips">
          <% @filter.queries.each do |query| %>
            <%= render 'filter_chip', name: 'q', value: query, label: query, icon: 'query' %>
          <% end %>
          <% @filter.genres.each do |genre| %>
            <%= render 'filter_chip', name: 'g', value: genre, label: genre, icon: 'query' %>
          <% end %>
          <% @filter.location_list.each do |location| %>
            <%= render 'filter_chip', name: 'l', value: location, label: location_display(location), icon: Location.type_for(location) %>
          <% end %>
          <% @filter.date_ranges.each do |range| %>
            <%= render 'filter_chip', name: 'd', value: range, label: date_range_label(range), icon: 'date' %>
          <% end %>
        </div>
        <%= render 'notify_button' %>
      </div>
    <% end %>

    <%# ── WHAT sheet — styles + free-text query ── %>
    <section class="sheet" role="dialog" aria-modal="true" aria-hidden="true"
             aria-label="<%= t('events.filter.sheet.what') %>"
             data-filter-sheets-target="sheet" data-field="what">
      <header class="sheet__header">
        <button type="button" class="sheet__close ph ph-x" data-action="filter-sheets#close" aria-label="<%= t('events.filter.close') %>"></button>
        <h2 class="sheet__title"><%= t('events.filter.sheet.what') %></h2>
        <button type="button" class="sheet__clear" data-action="filter-sheets#clear" data-filter-sheets-field-param="what"><%= t('events.filter.clear') %></button>
      </header>
      <div class="sheet__search">
        <span class="sheet__search-icon ph ph-magnifying-glass"></span>
        <input type="search" class="sheet__search-input" enterkeyhint="search" autocomplete="off"
               placeholder="<%= t('events.filter.what') %>"
               data-action="input->filter-sheets#filter keydown->filter-sheets#commitTyped">
      </div>
      <div class="sheet__body">
        <%# The thing a fixed list can't do: turn whatever you typed into a search. %>
        <button type="button" class="opt opt--newquery" hidden data-action="filter-sheets#addQuery">
          <span class="opt__box"><span class="ph ph-magnifying-glass"></span></span>
          <span class="opt__label" data-newquery-label></span>
        </button>

        <%# Applied free-text queries (how a tapped genre arrives). No type label:
            styles, genres and free text are ONE descriptor vocabulary now, so the
            s[]/q[] split stays invisible here — mirrors the unified desktop chip. %>
        <div class="sheet__queries" data-filter-sheets-target="queries">
          <% @filter.queries.each do |query| %>
            <label class="opt opt--query">
              <input type="checkbox" name="q[]" value="<%= query %>" checked>
              <span class="opt__box"></span>
              <span class="opt__label"><%= query %></span>
            </label>
          <% end %>
        </div>

        <%# Curated GENRE TREE — roots → children → grandchildren, rendered through
            the same collapsible markup as the Where sheet's canton > city > venue so
            What and Where read identically. A pick commits its g[] genre, which
            matches that genre + every descendant (Filter#expanded_genre_names). The
            search box filters the whole tree live (data-search). %>
        <% genre_filter_tree.each do |root| %>
          <div class="loc-group collapsed" data-filter-sheets-target="group">
            <div class="loc-group__head">
              <label class="opt opt--canton" data-search="<%= root[:search] %>">
                <input type="checkbox" name="g[]" value="<%= root[:value] %>" <%= 'checked' if @filter.genres.include?(root[:value]) %>>
                <span class="opt__box"></span>
                <span class="opt__label"><%= root[:name] %></span>
              </label>
              <button type="button" class="loc-group__toggle" data-action="filter-sheets#toggleGroup"
                      aria-label="<%= root[:name] %>">
                <span class="loc-group__count"><%= root[:count] %></span>
                <span class="loc-group__chevron ph ph-caret-down"></span>
              </button>
            </div>
            <div class="loc-group__body">
              <% root[:children].each do |child| %>
                <label class="opt opt--city" data-search="<%= child[:search] %>">
                  <input type="checkbox" name="g[]" value="<%= child[:value] %>" <%= 'checked' if @filter.genres.include?(child[:value]) %>>
                  <span class="opt__box"></span>
                  <span class="opt__label"><%= child[:name] %></span>
                  <span class="opt__count"><%= child[:count] %></span>
                </label>
                <% child[:children].each do |grandchild| %>
                  <label class="opt opt--venue" data-search="<%= grandchild[:search] %>">
                    <input type="checkbox" name="g[]" value="<%= grandchild[:value] %>" <%= 'checked' if @filter.genres.include?(grandchild[:value]) %>>
                    <span class="opt__box"></span>
                    <span class="opt__label"><%= grandchild[:name] %></span>
                    <span class="opt__count"><%= grandchild[:count] %></span>
                  </label>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
      <footer class="sheet__footer">
        <button type="button" class="sheet__apply" data-action="filter-sheets#apply"><%= t('events.filter.apply') %></button>
      </footer>
    </section>

    <%# ── WHERE sheet — canton > city > venue tree ── %>
    <section class="sheet" role="dialog" aria-modal="true" aria-hidden="true"
             aria-label="<%= t('events.filter.sheet.where') %>"
             data-filter-sheets-target="sheet" data-field="where">
      <header class="sheet__header">
        <button type="button" class="sheet__close ph ph-x" data-action="filter-sheets#close" aria-label="<%= t('events.filter.close') %>"></button>
        <h2 class="sheet__title"><%= t('events.filter.sheet.where') %></h2>
        <button type="button" class="sheet__clear" data-action="filter-sheets#clear" data-filter-sheets-field-param="where"><%= t('events.filter.clear') %></button>
      </header>
      <div class="sheet__search">
        <span class="sheet__search-icon ph ph-magnifying-glass"></span>
        <input type="search" class="sheet__search-input" enterkeyhint="search" autocomplete="off"
               placeholder="<%= t('events.filter.search_where') %>"
               data-action="input->filter-sheets#filter">
      </div>
      <div class="sheet__body">
        <% location_filter_tree.each do |canton| %>
          <div class="loc-group collapsed" data-filter-sheets-target="group">
            <div class="loc-group__head">
              <label class="opt opt--canton" data-search="<%= canton[:search] %>">
                <input type="checkbox" name="l[]" value="<%= canton[:value] %>" <%= 'checked' if @filter.location_list.include?(canton[:value]) %>>
                <span class="opt__box"></span>
                <span class="opt__label"><%= canton[:name] %></span>
                <span class="opt__type"><%= t('events.filter.location_types.canton') %></span>
              </label>
              <button type="button" class="loc-group__toggle" data-action="filter-sheets#toggleGroup"
                      aria-label="<%= canton[:name] %>">
                <span class="loc-group__count"><%= canton[:count] %></span>
                <span class="loc-group__chevron ph ph-caret-down"></span>
              </button>
            </div>
            <div class="loc-group__body">
              <% canton[:children].each do |city| %>
                <label class="opt opt--city" data-search="<%= city[:search] %>">
                  <input type="checkbox" name="l[]" value="<%= city[:value] %>" <%= 'checked' if @filter.location_list.include?(city[:value]) %>>
                  <span class="opt__box"></span>
                  <span class="opt__label"><%= city[:name] %></span>
                  <span class="opt__type"><%= t('events.filter.location_types.city') %></span>
                  <span class="opt__count"><%= city[:count] %></span>
                </label>
                <% city[:children].each do |venue| %>
                  <label class="opt opt--venue" data-search="<%= venue[:search] %>">
                    <input type="checkbox" name="l[]" value="<%= venue[:value] %>" <%= 'checked' if @filter.location_list.include?(venue[:value]) %>>
                    <span class="opt__box"></span>
                    <span class="opt__label"><%= venue[:name] %></span>
                    <span class="opt__count"><%= venue[:count] %></span>
                  </label>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
      <footer class="sheet__footer">
        <button type="button" class="sheet__apply" data-action="filter-sheets#apply"><%= t('events.filter.apply') %></button>
      </footer>
    </section>

    <%# ── WHEN sheet — presets + custom range (native OS date pickers) ── %>
    <section class="sheet" role="dialog" aria-modal="true" aria-hidden="true"
             aria-label="<%= t('events.filter.sheet.when') %>"
             data-filter-sheets-target="sheet" data-field="when">
      <header class="sheet__header">
        <button type="button" class="sheet__close ph ph-x" data-action="filter-sheets#close" aria-label="<%= t('events.filter.close') %>"></button>
        <h2 class="sheet__title"><%= t('events.filter.sheet.when') %></h2>
        <button type="button" class="sheet__clear" data-action="filter-sheets#clear" data-filter-sheets-field-param="when"><%= t('events.filter.clear') %></button>
      </header>
      <div class="sheet__body">
        <% Datepicker.preset.each do |key, preset| %>
          <label class="opt">
            <input type="checkbox" name="d[]" value="<%= key %>" <%= 'checked' if @filter.date_ranges.include?(key.to_s) %>>
            <span class="opt__box"></span>
            <span class="opt__label"><%= preset[:label] %></span>
          </label>
        <% end %>

        <div class="opt opt--custom">
          <span class="opt__type"><%= t('events.filter.custom_range') %></span>
          <div class="custom-range">
            <input type="date" class="custom-range__input" aria-label="<%= t('events.filter.date_from') %>"
                   value="<%= custom_start %>"
                   data-filter-sheets-target="customStart" data-action="change->filter-sheets#customRange">
            <span class="custom-range__sep ph ph-arrow-right" aria-hidden="true"></span>
            <input type="date" class="custom-range__input" aria-label="<%= t('events.filter.date_to') %>"
                   value="<%= custom_end %>"
                   data-filter-sheets-target="customEnd" data-action="change->filter-sheets#customRange">
          </div>
          <%# Hidden input that actually submits the custom range as "start - end". %>
          <input type="checkbox" name="d[]" hidden
                 value="<%= custom_range %>" <%= 'checked' if custom_range.present? %>
                 data-filter-sheets-target="customValue">
        </div>
      </div>
      <footer class="sheet__footer">
        <button type="button" class="sheet__apply" data-action="filter-sheets#apply"><%= t('events.filter.apply') %></button>
      </footer>
    </section>
  <% end %>
</div>
