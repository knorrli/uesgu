<%# The ★ save control for the active filter, pinned to the right of the
    applied-filter chips. Logged-in users with an active filter only (an empty
    filter would be an "all events" firehose we don't offer).

    ONE button, showing only saved / not-saved (notification state lives in the
    editor, not here):
      • not saved → outline ★. Links to the editor with this filter as an unsaved
        draft (new → create); nothing is persisted until the user hits Save.
      • saved     → filled ★ (active). Links straight to the existing saved
        filter's editor (fingerprint dedup — no clone).

    Icon-only: the button rides the chip row's reserved height (padding gives the
    hit area, negative margin cancels the growth — see .save-filter-link). The
    accessible name lives on aria-label. %>
<% if current_user.present? && @filter.active? %>
  <div class="filter-actions flex flex-row align-center">
    <% if @notify_rule %>
      <%# Saved: a solid (filled) funnel — opens the existing filter's editor. The
          fill vs. the not-saved outline is the at-a-glance state cue. %>
      <%= link_to edit_notification_rule_path(@notify_rule),
            class: 'save-filter-link active',
            'aria-label': t('events.index.save_filter_saved') do %>
        <span class="funnel-fill" aria-hidden="true"></span>
      <% end %>
    <% else %>
      <%# Not saved: a funnel with a small + badge ("add this filter") — opens the
          editor with the current filter as a draft. %>
      <%= link_to new_notification_rule_path(q: @filter.queries, g: @filter.genres,
                    l: @filter.location_list, s: @filter.style_list, d: @filter.date_ranges),
            class: 'save-filter-link',
            'aria-label': t('events.index.save_filter') do %>
        <span class="save-filter-icon">
          <span class="ph ph-funnel" aria-hidden="true"></span>
          <span class="save-filter-plus" aria-hidden="true">+</span>
        </span>
      <% end %>
    <% end %>
  </div>
<% end %>
