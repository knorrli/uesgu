<%# A single day's events, grouped under their venue so a venue hosting several
    events that day shows its name once. Chronological by start time; untimed
    events sort last. Used by the list view, the calendar day drawer, and (read
    only, interactive: false) the admin genre-editor preview. %>
<% interactive = local_assigns.fetch(:interactive, true) %>
<% groups = events
     .sort_by { |event| [event.start_time ? 0 : 1, event.start_time, event.title.to_s] }
     .group_by { |event| event.venue&.name || "event-#{event.id}" } %>
<div class="venue-groups flex flex-col gap-large">
  <% groups.each_value do |group| %>
    <% lead = group.first %>
    <% venue = lead.venue %>
    <%# Venue is the anchor (own line, headline size); city/canton drop to a quiet
        metadata line beneath it, so the hierarchy reads the same logged in or out.
        With no venue, the first location is promoted to the anchor so the group
        still has a headline. %>
    <% locations = lead.locations.to_a %>
    <% anchor = venue || locations.first %>
    <% meta_locations = locations.reject { |location| location == anchor } %>
    <%# Location names in this group that explain an interest match (a followed
        venue/place) and aren't already an applied filter — flagged amber below. %>
    <% why_locs = interactive ? interest_location_names(group) : Set.new %>
    <section class="venue-group flex flex-col gap-small">
      <% if anchor %>
        <div class="venue-header flex flex-col gap-xsmall">
          <div class="event-where"><% if why_locs.include?(anchor.name) %><span class="interest-flag" aria-hidden="true"><i class="ph ph-flag"></i></span><% end %><%= event_filter_tag anchor.name, field: 'l[]', value: anchor.name, interactive: interactive,
                  modifier: 'venue' %></div>
          <% if meta_locations.any? %>
            <div class="event-where-meta">
              <% meta_locations.each_with_index do |location, i| %>
                <% if i > 0 %><span class="sep" aria-hidden="true">&middot;</span><% end %><% if why_locs.include?(location.name) %><span class="interest-flag" aria-hidden="true"><i class="ph ph-flag"></i></span><% end %><%= event_filter_tag location.name, field: 'l[]', value: location.name, interactive: interactive %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
      <div class="venue-events flex flex-col gap-medium">
        <% group.each do |event| %>
          <%= render event, filter: filter, interactive: interactive %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
