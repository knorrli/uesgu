<%# The home/listing page's tab is just the brand — it sets no content_for(:title),
    so the layout's bare "üsgu" fallback applies (a "üsgu — üsgu" would be silly). %>
<%# This page renders list OR calendar for the SAME url depending on the saved
    view preference (session/account) — which Turbo's url-keyed snapshot cache
    can't represent, so a cached snapshot of the other view flashes on navigation
    (the list↔calendar flicker). Opt out of the snapshot cache so every visit
    renders fresh. %>
<% content_for :head do %><meta name="turbo-cache-control" content="no-cache"><% end %>

<div class="flex flex-col gap-large align-stretch">
  <%# One filter UI for all widths (the genre/location tree pickers + when): a
      trigger bar that opens full-screen sheets on mobile and inline dropdown
      panels on desktop (CSS-only difference). The same genre/location tree sheets
      (tags/_genre_sheet, _location_sheet) are reused by the rule editor. %>
  <%= render 'filter_sheets' %>

  <%# The list/calendar view switcher, above the content in both views (so the
      first bold header lines up across views). %>
  <div class="events-toolbar flex justify-end align-center gap-medium">
    <%= render 'view_switcher', view: @view %>
  </div>

  <% unless @has_results %>
    <p class="muted events-empty"><%= t('events.index.empty') %></p>
  <% end %>

  <% if @view == 'calendar' %>
    <%= render 'calendar', events: @events %>
  <% elsif @events.any? %>
    <%= render 'events', events: @events %>
  <% end %>
</div>

