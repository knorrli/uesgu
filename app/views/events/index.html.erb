<% content_for :title, t('events.index.title') %>

<div class="flex flex-col gap-xlarge align-stretch" data-controller="filter">
  <%= render 'filter', filter: @filter %>

  <%= render 'view_switcher', view: @view %>

  <% if @view == 'calendar' %>
    <%= render 'calendar', events: @events %>
  <% else %>
    <%= render 'events', events: @events %>
  <% end %>
</div>

