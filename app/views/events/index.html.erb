<%# The home/listing page's tab is just the brand — it sets no content_for(:title),
    so the layout's bare "üsgu" fallback applies (a "üsgu — üsgu" would be silly). %>
<%# This page renders list OR calendar for the SAME url depending on the saved
    view preference (session/account) — which Turbo's url-keyed snapshot cache
    can't represent, so a cached snapshot of the other view flashes on navigation
    (the list↔calendar flicker, e.g. after switching view then tapping "My
    interests"). Opt out of the snapshot cache so every visit renders fresh. %>
<% content_for :head do %><meta name="turbo-cache-control" content="no-cache"><% end %>

<div class="flex flex-col gap-large align-stretch" data-controller="favorite"
     data-action="turbo:before-frame-render->favorite#beforeFrameRender turbo:frame-load->favorite#reapply"
     data-favorite-followed-value="<%= favorite_followed_keys.to_json %>">
  <%# Two presentations of the same filter, CSS-toggled at 600px: the inline
      combobox filter on wider screens, full-screen sheets on mobile. Each is an
      independent GET form producing identical params; only the visible one is
      interactive, so they never collide. %>
  <div class="filter-desktop"><%= render 'filter', filter: @filter %></div>
  <%= render 'filter_sheets' %>

  <%# Toggle row, above the content in both views (so the first bold header lines
      up across views). The left holds the "my interests" filter shortcut; the
      "notify me about this filter" action lives down by the filter chips (where
      its meaning is clear), so this row stays identical whether or not a filter
      is active. align-center, since on mobile the left can be a lone star icon
      with no text baseline to ride on. %>
  <div class="events-toolbar flex justify-between align-center gap-medium">
    <div class="events-toolbar__left flex align-center gap-medium">
      <%= render 'favorites_filter' %>
    </div>
    <%= render 'view_switcher', view: @view %>
  </div>

  <% if @events.empty? %>
    <p class="muted events-empty"><%= t('events.index.empty') %></p>
  <% end %>

  <% if @view == 'calendar' %>
    <%= render 'calendar', events: @events %>
  <% elsif @events.any? %>
    <%= render 'events', events: @events %>
  <% end %>
</div>

