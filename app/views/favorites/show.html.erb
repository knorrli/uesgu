<% content_for :title, t('favorites.title') %>

<div class="flex flex-col gap-large">
  <h1><%= t('favorites.title') %></h1>
  <p class="muted"><%= t('favorites.intro') %></p>

  <%= form_with model: @user, url: favorites_path, method: :patch, class: 'flex flex-col gap-large' do |form| %>
    <% if @user.errors.any? %>
      <ul class="form-errors">
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    <% end %>

    <section class="flex flex-col gap-small">
      <h2><%= t('settings.favorite_styles_heading') %></h2>
      <%# Same checkbox control as the location picker below (label.loc-option), so
          Styles and Places read as one consistent boolean paradigm — just a flat
          wrapping row here vs. the hierarchical tree there. %>
      <div class="flex flex-row wrap gap-medium">
        <%= form.collection_check_boxes :style_list, Style.order(name: :asc), :name, :name do |b| %>
          <label class="loc-option"><%= b.check_box %> <span class="loc-name"><%= b.text %></span></label>
        <% end %>
      </div>
    </section>

    <section class="flex flex-col gap-small">
      <h2><%= t('settings.favorite_locations_heading') %></h2>
      <p class="muted"><%= t('settings.favorite_locations_hint') %></p>
      <div class="location-picker"><%= render 'location_picker', user: @user %></div>
    </section>

    <%= form.submit t('favorites.save') %>
  <% end %>
</div>
