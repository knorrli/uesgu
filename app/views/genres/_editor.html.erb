<%# Shared genre → style editor (tinder queue, per-genre CRUD edit, inline edit).
    A few quick-select suggestion buttons cover the common case; the combobox
    handles anything else (and multi-style genres). `return_to` decides where
    each action lands: the queue passes its own path (next genre), the others
    return to their page. %>
<section class="flex flex-col gap-medium" data-controller="style-picker">
  <div class="flex justify-between align-baseline gap-medium wrap">
    <h2><%= genre.name %></h2>
    <span class="muted"><%= t('genres.editor.usage', count: genre.events_count) %></span>
  </div>

  <% if suggestions.any? %>
    <div class="flex flex-col gap-small">
      <h4><%= t('genres.editor.suggested') %></h4>
      <div class="flex gap-small wrap">
        <%# A click adds the style to the combobox below (composes with it),
            rather than committing — Assign commits the whole selection. %>
        <% suggestions.each do |style| %>
          <button type="button" class="tag"
                  data-action="style-picker#add"
                  data-style-picker-style-id-param="<%= style.id %>"><%= style.name %></button>
        <% end %>
      </div>
    </div>
  <% end %>

  <%= form_with model: genre, url: genre_path(genre), method: :patch,
        class: 'flex justify-between gap-medium wrap align-end' do |f| %>
    <%= hidden_field_tag :return_to, return_to %>
    <div class="input-wrapper flex flex-grow">
      <%= f.combobox :style_ids, Style.order(name: :asc),
            value: genre.style_ids.join(','),
            id: "genre_#{genre.id}",
            placeholder: Style.model_name.human(count: :many),
            multiselect_chip_src: chips_styles_path do |combobox| %>
        <% combobox.customize_fieldset class: 'flex-grow' %>
        <% combobox.customize_input class: 'flex-grow' %>
      <% end %>
    </div>
    <%= f.submit t('genres.editor.assign') %>
  <% end %>

  <%# Three terminal dispositions besides Assign (which lives in the form above):
      ignore = keep the genre but leave it unmapped; hide = non-music, drop the
      event; block = scraper noise, strip the tag entirely. %>
  <div class="flex gap-small wrap genre-dispositions">
    <%= button_to t('genres.editor.ignore'), ignore_genre_path(genre), params: { return_to: return_to } %>
    <%= button_to t('genres.editor.hide'), hide_genre_path(genre), params: { return_to: return_to } %>
    <%= button_to t('genres.editor.block'), block_genre_path(genre), params: { return_to: return_to } %>
  </div>

  <% if sample_events.any? %>
    <div class="flex flex-col gap-medium">
      <h4><%= t('genres.editor.appears_on') %></h4>
      <%# Reuse the real event card so the full extracted context (subtitle,
          styles, sibling genres) is visible. interactive:false renders it
          read-only; the date + venue (which the card omits, the list shows them
          via grouping) sit in a muted header above each. %>
      <% sample_events.each do |event| %>
        <div class="genre-sample-event flex flex-col gap-small">
          <span class="muted">
            <%= event.start_date.strftime('%d.%m.%y') %><% if event.venue %> &middot; <%= event.venue.name %><% end %>
          </span>
          <%= render event, interactive: false %>
        </div>
      <% end %>
    </div>
  <% end %>
</section>
