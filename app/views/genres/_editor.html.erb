<%# Shared genre editor (tinder queue, per-genre edit, inline edit). The primary
    action files the genre into the tree under a parent; the rest are dispositions
    + merge. `return_to` decides where each action lands: the queue passes its own
    path (next genre), the others return to their page. %>
<section class="flex flex-col gap-large">
  <%# Filing group: the genre's name, its current disposition (if any), the
      primary "set parent" action and the disposition alternatives — one block,
      since they're the same decision ("where does this genre go?"). %>
  <div class="flex flex-col gap-medium">
    <h2><%= genre.name %></h2>

    <%# Current disposition + an inline Restore, shown only once a genre has one.
        Explains an otherwise-mysterious empty editor (a blocked genre tags 0
        events, since block stripped them). %>
    <% if genre.aliased? %>
      <div class="flex gap-medium align-baseline wrap genre-current-status">
        <span class="muted"><%= t('genres.editor.status') %> <strong><%= t('genres.index.status_merged', canonical: genre.canonical.name) %></strong></span>
        <%= button_to t('genres.queue.restore'), restore_genre_path(genre), params: { return_to: return_to } %>
      </div>
    <% elsif genre.ignored? || genre.hidden? || genre.blocked? %>
      <% status_key = genre.hidden? ? 'status_hidden' : genre.blocked? ? 'status_blocked' : 'status_ignored' %>
      <div class="flex gap-medium align-baseline wrap genre-current-status">
        <span class="muted"><%= t('genres.editor.status') %> <strong><%= t("genres.index.#{status_key}") %></strong></span>
        <%= button_to t('genres.queue.restore'), restore_genre_path(genre), params: { return_to: return_to } %>
      </div>
    <% elsif genre.placed? %>
      <div class="flex gap-medium align-baseline wrap genre-current-status">
        <span class="muted"><%= t('genres.editor.status') %> <strong><%= t('genres.index.placed_under', parent: genre.parent.name) %></strong></span>
        <%= button_to t('genres.queue.restore'), restore_genre_path(genre), params: { return_to: return_to } %>
      </div>
    <% end %>

    <%# Primary curation action: file this genre into the tree under a parent (e.g.
        Crustpunk → Punk). Blank = a top-level (root) genre. Parents exclude this
        genre and its own descendants (which would form a cycle) and any
        hidden/blocked/aliased genre. The parent-based successor to "Assign".
        Ordered (via genre_combobox_options) by each candidate's descendant count,
        also shown right-aligned in the dropdown, so the broad umbrella genres you
        reach for most (Rock, Electronic …) — the ones that already have sub-genres
        — sit at the top instead of being scattered alphabetically. The count is
        render-only, so typing still filters on the name. %>
    <% parent_candidates = Genre.where(hidden_at: nil, blocked_at: nil, canonical_id: nil)
                                .where.not(id: [genre.id, *genre.descendant_ids]) %>
    <% parent_options = genre_combobox_options(parent_candidates) %>
    <%= form_with url: set_parent_genre_path(genre), method: :post, scope: :genre,
          class: 'flex justify-between gap-medium wrap align-end genre-set-parent' do |f| %>
      <%= hidden_field_tag :return_to, return_to %>
      <div class="input-wrapper flex flex-grow">
        <%= f.combobox :parent_genre_id, parent_options,
              value: genre.parent_id,
              placeholder: t('genres.editor.set_parent_into') do |combobox| %>
          <% combobox.customize_fieldset class: 'flex-grow' %>
          <% combobox.customize_input class: 'flex-grow' %>
        <% end %>
      </div>
      <%= f.submit t('genres.editor.set_parent') %>
    <% end %>

    <%# Three terminal dispositions besides "set parent" (the form above): ignore =
        keep the genre but leave it unfiled; hide = non-music, drop the event; block
        = scraper noise, strip the tag entirely. %>
    <div class="flex gap-small wrap genre-dispositions">
      <%= button_to t('genres.editor.ignore'), ignore_genre_path(genre), params: { return_to: return_to } %>
      <%= button_to t('genres.editor.hide'), hide_genre_path(genre), params: { return_to: return_to } %>
      <%= button_to t('genres.editor.block'), block_genre_path(genre), params: { return_to: return_to } %>
    </div>
  </div>

  <%# Merge group: fold this genre into another. A hairline + air (genre-editor-
      section) sets it apart from the filing decision above. %>
  <div class="flex flex-col gap-medium genre-editor-section">
    <%# "Did you mean" — the closest existing genres by fingerprint similarity
        (levenshtein), e.g. "postpunkz" → "Post-Punk". One click merges. %>
    <% if alias_suggestions.any? %>
      <div class="flex flex-col gap-small">
        <h3><%= t('genres.editor.merge_suggested') %></h3>
        <div class="flex gap-small wrap">
          <% alias_suggestions.each do |candidate| %>
            <%= button_to candidate.name, merge_genre_path(genre),
                  params: { genre: { canonical_genre_id: candidate.id }, return_to: return_to },
                  class: 'tag' %>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Merge into a canonical genre — a semantic alias the fingerprint can't catch
        (e.g. "Elektronik" → "Electronic"). Folds this genre's events onto the
        canonical and auto-resolves it on every future scrape. Ordered most-used
        first, since you merge variants into the popular real genre. %>
    <%= form_with url: merge_genre_path(genre), method: :post, scope: :genre,
          class: 'flex justify-between gap-medium wrap align-end genre-merge' do |f| %>
      <%= hidden_field_tag :return_to, return_to %>
      <div class="input-wrapper flex flex-grow">
        <%= f.combobox :canonical_genre_id, Genre.listable.where.not(id: genre.id).by_usage,
              placeholder: t('genres.editor.merge_into') do |combobox| %>
          <% combobox.customize_fieldset class: 'flex-grow' %>
          <% combobox.customize_input class: 'flex-grow' %>
        <% end %>
      </div>
      <%= f.submit t('genres.editor.merge') %>
    <% end %>
  </div>

  <% if sample_events.any? %>
    <div class="flex flex-col gap-medium genre-editor-section">
      <div class="flex justify-between align-baseline gap-medium wrap">
        <h3><%= t('genres.editor.appears_on') %></h3>
        <span class="muted"><%= t('genres.editor.usage', count: genre.events_count) %></span>
      </div>
      <%# Reuse the real event card so the full extracted context (description,
          styles, sibling genres) is visible. interactive:false renders it
          read-only; the date + venue (which the card omits, the list shows them
          via grouping) sit in a muted header above each. %>
      <% sample_events.each do |event| %>
        <div class="genre-sample-event flex flex-col gap-small">
          <span class="muted">
            <%= event.start_date.strftime('%d.%m.%y') %><% if event.venue %> &middot; <%= event.venue.name %><% end %>
          </span>
          <%= render event, interactive: false %>
        </div>
      <% end %>
    </div>
  <% end %>
</section>
