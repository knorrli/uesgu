<div class="flex flex-col gap-large">
  <%= render 'admin/back' %>
  <div class="flex justify-between align-baseline gap-medium wrap">
    <h1><%= t('.title') %></h1>
    <div class="flex gap-medium align-baseline wrap">
      <%= link_to t('.tree_link'), tree_genres_path %>
      <%= link_to t('.queue_link'), queue_genres_path %>
    </div>
  </div>

  <%# Two groups: assignment status (all / assigned / unassigned), then the
      parked dispositions (ignored / hidden / blocked) where Restore lives. %>
  <div class="flex gap-small wrap align-baseline genre-status-filters">
    <% %w[all assigned unassigned].each do |status| %>
      <%= link_to t(".status_#{status}"),
            genres_path(status: (status == 'all' ? nil : status), q: params[:q].presence),
            class: class_names(:tag, active: @status == status) %>
    <% end %>
    <span class="filter-divider" aria-hidden="true"></span>
    <% %w[ignored hidden blocked].each do |status| %>
      <%= link_to t(".status_#{status}"),
            genres_path(status: status, q: params[:q].presence),
            class: class_names(:tag, active: @status == status) %>
    <% end %>
  </div>

  <%= form_with url: genres_path, method: :get, data: { turbo_frame: '_top' } do %>
    <%= hidden_field_tag :status, params[:status] if params[:status].present? %>
    <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
    <div class="input-wrapper flex">
      <%= text_field_tag :q, params[:q], placeholder: t('.search'), autocomplete: 'off' %>
    </div>
  <% end %>

  <div class="flex gap-small align-baseline muted genre-sort">
    <span><%= t('.sort_by') %></span>
    <% %w[name count].each do |sort| %>
      <%= link_to t(".sort_#{sort}"),
            genres_path(status: params[:status].presence, q: params[:q].presence, sort: sort),
            class: class_names('genre-sort-option', active: @sort == sort) %>
    <% end %>
  </div>

  <%# Left-aligned and tight so name, count and status read as one row (the old
      justify-between stranded the status far right). The count makes the sort
      legible. %>
  <div class="flex flex-col gap-small">
    <% @genres.each do |genre| %>
      <div class="flex align-baseline gap-medium wrap genre-row">
        <%= link_to genre.name, edit_genre_path(genre) %>
        <span class="muted genre-count" title="<%= t('genres.editor.usage', count: genre.events_count) %>"><%= genre.events_count %>&times;</span>
        <div class="flex gap-small wrap align-baseline">
          <% if genre.aliased? %>
            <span class="muted"><%= t('.status_merged', canonical: genre.canonical.name) %></span>
            <%= button_to t('genres.queue.restore'), restore_genre_path(genre),
                  params: { return_to: genres_path(status: params[:status].presence, q: params[:q].presence, sort: params[:sort].presence) } %>
          <% elsif genre.ignored? || genre.hidden? || genre.blocked? %>
            <% status_key = genre.hidden? ? '.status_hidden' : genre.blocked? ? '.status_blocked' : '.status_ignored' %>
            <span class="muted"><%= t(status_key) %></span>
            <%= button_to t('genres.queue.restore'), restore_genre_path(genre),
                  params: { return_to: genres_path(status: params[:status].presence, q: params[:q].presence, sort: params[:sort].presence) } %>
          <% elsif genre.styles.any? %>
            <% genre.styles.each do |style| %><span class="chip"><%= style.name %></span><% end %>
          <% else %>
            <span class="muted"><%= t('.status_unassigned') %></span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="flex justify-center">
    <%= paginate @genres %>
  </div>
</div>
