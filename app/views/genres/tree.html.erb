<div class="flex flex-col gap-large">
  <%= render layout: "shared/page_header", locals: { back_path: admin_path, back_label: t("admin.back") } do %>
    <div class="flex justify-between align-baseline gap-medium wrap">
      <h1><%= t('.title') %></h1>
      <%= link_to t('genres.index.title'), genres_path %>
    </div>
  <% end %>

  <%# Read-only — each genre links to its editor (where you set the parent). %>
  <p class="muted">
    <%= t('.summary', roots: @roots.size, placed: @placed) %>
    <% if @unplaced.positive? %>
      &middot; <%= link_to t('.unplaced', count: @unplaced), queue_genres_path %>
    <% end %>
  </p>

  <% if @roots.any? %>
    <ul class="genre-tree">
      <% @roots.each do |root| %>
        <%= render 'tree_node', genre: root, children_map: @children %>
      <% end %>
    </ul>
  <% else %>
    <p class="muted"><%= t('.empty') %></p>
  <% end %>
</div>
