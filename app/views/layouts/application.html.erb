<!DOCTYPE html>
<% theme = cookies[:theme].presence_in(%w[light dark]) %>
<html<%= " data-theme=\"#{theme}\"".html_safe if theme %>>
  <head>
    <title><%= content_for(:title) || "üsgu" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# PWA manifest makes the app installable; routes enabled in config/routes.rb. %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%# Canonical set: the theme-aware SVG is what modern browsers use; the .ico
        (sizes="any") is the legacy fallback they skip when an SVG is present. The
        512px PNG is intentionally NOT a <link rel=icon> — it's a dark raster that
        Chrome would prefer from cache over the SVG (favicon flashes light, then
        flips dark). The PWA manifest still references it for the installed app. %>
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link id="favicon-svg" rel="icon" href="<%= theme == 'light' ? '/icon-light.svg' : '/icon.svg' %>" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%# The server set <html data-theme> and the favicon above from the `theme`
        cookie. On the very first visit there's no cookie yet, so it's unset:
        resolve from the OS, set the favicon, and persist a cookie so every later
        request renders the right theme + icon with no flash. Pre-paint (still in
        <head>), so no visible theme flash. %>
    <script nonce="<%= content_security_policy_nonce %>">
      (function () {
        if (document.documentElement.dataset.theme) return
        var t = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"
        document.documentElement.dataset.theme = t
        document.cookie = "theme=" + t + ";path=/;max-age=31536000;samesite=lax"
        var el = document.getElementById("favicon-svg")
        if (el) el.href = t === "light" ? "/icon-light.svg" : "/icon.svg"
      })()
    </script>

    <%= combobox_style_tag %>
    <%= stylesheet_link_tag 'easepick.min.css', "data-turbo-track": "reload" %>
    <%# <%= stylesheet_link_tag '_easepick_overrides.css', "data-turbo-track": "reload" %1> %>
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if notice.present? || alert.present? %>
      <div class="flashes" role="status" aria-live="polite">
        <% if notice.present? %><p class="flash notice"><%= notice %></p><% end %>
        <% if alert.present? %><p class="flash alert"><%= alert %></p><% end %>
      </div>
    <% end %>

    <header class="site-header">
      <div class="site-header__inner">
        <%# Brand doubles as the home link; the theme switcher sits beside it
            (icon-only) and stays visible whether signed in or not. %>
        <div class="site-header__brand">
          <%= link_to 'üsgu', root_path, class: 'site-brand' %>
          <button type="button" class="theme-toggle" aria-label="<%= t('nav.theme') %>"
                  data-controller="theme" data-action="theme#toggle">
            <span class="ph <%= theme == 'light' ? 'ph-sun' : 'ph-moon' %>" data-theme-target="icon" aria-hidden="true"></span>
          </button>
        </div>
        <nav class="site-nav">
          <%# Install shortcut, visible signed in or out (installing needs no
              account). Ships hidden; the install-link controller reveals it only
              where the PWA can actually be installed (not when already installed,
              and not on Firefox desktop). %>
          <%= link_to t('nav.install'), install_path, class: 'nav-install', hidden: true, data: { controller: 'install-link' } %>
          <% if authenticated? %>
            <% unread = current_user.notifications.unread.count %>
            <%# Personal/account links collapse into one menu to keep the bar light.
                A dot on the trigger preserves the at-a-glance unread signal now
                that the Notifications link lives inside the menu. %>
            <details class="nav-menu" data-controller="menu" data-action="toggle->menu#toggle">
              <summary><%= current_user.username %><% if unread.positive? %> <span class="unread-dot" role="img" aria-label="<%= t('nav.unread_notifications') %>"></span><% end %></summary>
              <div class="nav-menu__items">
                <%# Reused icons (bell/bookmark/heart/gear) so the labels scan at a
                    glance — the heart/bookmark in particular tell the Interessen and
                    Merkliste rows apart. Notification rules now live as a tab inside
                    the Inbox; logout moved to Settings. %>
                <%= link_to notifications_path, class: 'nav-menu__item' do %>
                  <span class="ph ph-bell" aria-hidden="true"></span>
                  <span><%= t('nav.notifications') %></span><% if unread.positive? %> <span class="badge"><%= unread %></span><% end %>
                <% end %>
                <%= link_to saved_events_path, class: 'nav-menu__item' do %>
                  <span class="ph ph-bookmark-simple" aria-hidden="true"></span>
                  <span><%= t('nav.saved') %></span>
                <% end %>
                <%= link_to favorites_path, class: 'nav-menu__item' do %>
                  <span class="fav-heart" aria-hidden="true"></span>
                  <span><%= t('nav.favorites') %></span>
                <% end %>
                <%= link_to settings_path, class: 'nav-menu__item' do %>
                  <span class="ph ph-gear" aria-hidden="true"></span>
                  <span><%= t('nav.settings') %></span>
                <% end %>
                <% if current_user.admin? %>
                  <%= link_to admin_path, class: 'nav-menu__item' do %>
                    <span class="ph ph-wrench" aria-hidden="true"></span>
                    <span><%= t('nav.admin') %></span>
                  <% end %>
                <% end %>
              </div>
            </details>
          <% else %>
            <%# Just "Log in" — signup is reached via the login page's "no account?
                register" link, keeping the header light (matters on mobile). %>
            <%= link_to t('nav.login'), new_session_path %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="content">
      <%= yield %>
    </main>

    <%= render 'shared/cookie_notice' %>
  </body>
</html>
