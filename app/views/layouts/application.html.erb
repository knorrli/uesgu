<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "üsgu" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= combobox_style_tag %>
    <%= stylesheet_link_tag 'easepick.min.css', "data-turbo-track": "reload" %>
    <%# <%= stylesheet_link_tag '_easepick_overrides.css', "data-turbo-track": "reload" %1> %>
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <%= link_to 'üsgu', root_path, class: 'site-brand' %>
        <nav class="site-nav">
          <%= link_to t('nav.events'), root_path %>
          <% if authenticated? %>
            <% if current_user&.admin? %>
              <%= link_to t('nav.admin'), admin_path %>
            <% end %>
            <%= link_to notifications_path do %>
              <%= t('nav.notifications') %><% if (unread = current_user.notifications.unread.count).positive? %> <span class="badge"><%= unread %></span><% end %>
            <% end %>
            <%= link_to t('nav.favorites'), favorites_path %>
            <%= link_to t('nav.settings'), settings_path %>
            <%= link_to t('nav.logout'), session_path, data: { turbo_method: :delete } %>
          <% else %>
            <%= link_to t('nav.login'), new_session_path %>
            <%= link_to t('nav.signup'), signup_path %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="content">
      <% if notice.present? %><p class="flash notice"><%= notice %></p><% end %>
      <% if alert.present? %><p class="flash alert"><%= alert %></p><% end %>
      <%= yield %>
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <%= t('footer.tagline') %>
      </div>
    </footer>
  </body>
</html>
