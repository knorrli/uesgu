<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="light">
    <meta name="supported-color-schemes" content="light">
  </head>
  <%# Mirrors the app's light theme: Space Mono (monospace identity, with a robust
      system-mono fallback since email clients can't be trusted to load a web font),
      cream ground, near-black text. Sharp corners + neutral hairlines + green-only-
      for-interaction are carried by the inline styles in the digest body. %>
  <body style="margin:0; padding:0; background:#d8cfb2; -webkit-font-smoothing:antialiased; font-family:'Space Mono', ui-monospace, 'SF Mono', 'Cascadia Mono', 'Roboto Mono', Menlo, Consolas, monospace; color:#1d1620;">
    <%= yield %>
  </body>
</html>
