<%# Shared by new + edit. form_with infers POST (create) vs PATCH (update) from
    the record. The filter (q/l/s/d) posts as top-level fields (read by the
    controller's filter_params, not nested under notification_rule) via inline
    multiselect comboboxes + a window select. The rule-form Stimulus controller
    keys the schedule off the window (windowed → derived cadence; none → free
    cadence); rhythms-value carries WINDOW_RHYTHM so it can pick the right
    firing-point control client-side. %>
<%= form_with model: rule, class: 'rule-form account-form flex flex-col gap-medium',
      data: { controller: 'rule-form', 'rule-form-rhythms-value': NotificationRule::WINDOW_RHYTHM.to_json } do |form| %>
  <% if rule.errors.any? %>
    <ul class="form-errors">
      <% rule.errors.full_messages.each { |m| %><li><%= m %></li><% } %>
    </ul>
  <% end %>

  <%# What this alert watches. Styles/locations are native multiselect comboboxes
      (chips rendered by tags#chips, the same endpoint the genre editor uses) and
      the window is a preset select — no events-page round-trip. Free-text queries
      aren't editable here (no fixed option to chip), but any carried from the
      events "Notify me" button are preserved + shown read-only. %>
  <fieldset class="rule-fieldset flex flex-col gap-medium">
    <legend><%= t('notification_rules.section_filter') %></legend>

    <%# "What" — styles AND free text in one field, like the landing-page filter:
        a pick matches a style, free text becomes a query. Locations are a second
        multiselect. Chips (incl. free text) render via tags#chips. Labels are
        dropped in favour of the placeholders, matching the main filter. %>
    <%# "What" — pick styles or type free text (→ a query), like the landing page.
        The tag-picker controller routes each into its own chip (s[] vs q[]). %>
    <div class="filter-field flex flex-col gap-small" data-controller="tag-picker"
         data-tag-picker-param-value="s[]" data-tag-picker-query-param-value="q[]">
      <div class="chips flex flex-row wrap gap-small" data-tag-picker-target="chips">
        <% filter.style_list.each { |s| %><%= render 'chip', param: 's[]', value: s %><% } %>
        <% filter.queries.each { |q| %><%= render 'chip', param: 'q[]', value: q %><% } %>
      </div>
      <div class="input-wrapper flex flex-grow" data-action="hw-combobox:selection->tag-picker#add">
        <%= combobox_tag 'style_pick', combobox_options(available_tags(context: :styles), value: :name),
              name_when_new: 'query', id: "rule_what_#{rule.id || 'new'}",
              placeholder: t('events.filter.what') do |combobox| %>
          <% combobox.customize_fieldset class: 'flex-grow' %>
        <% end %>
      </div>
    </div>

    <div class="filter-field flex flex-col gap-small" data-controller="tag-picker"
         data-tag-picker-param-value="l[]">
      <div class="chips flex flex-row wrap gap-small" data-tag-picker-target="chips">
        <% filter.location_list.each { |l| %><%= render 'chip', param: 'l[]', value: l %><% } %>
      </div>
      <div class="input-wrapper flex flex-grow" data-action="hw-combobox:selection->tag-picker#add">
        <%= combobox_tag 'location_pick', combobox_options(available_tags(context: :locations), value: :name),
              id: "rule_where_#{rule.id || 'new'}",
              placeholder: t('events.filter.where') do |combobox| %>
          <% combobox.customize_fieldset class: 'flex-grow' %>
        <% end %>
      </div>
    </div>

    <%= select_tag 'd[]', options_for_select(rule_window_options, filter.date_ranges.first),
          include_blank: t('notification_rules.window_none'),
          data: { 'rule-form-target': 'window', action: 'rule-form#update' } %>

    <p class="muted rule-hint">
      <% if filter.date_ranges.any? %><%= t('notification_rules.new.hint_happening') %><% else %><%= t('notification_rules.new.hint_added') %><% end %>
    </p>
  </fieldset>

  <% if matches_favorites %>
    <label class="rule-check rule-sync flex gap-small">
      <%= form.check_box :track_favorites %>
      <span>
        <%= t('notification_rules.track_favorites') %>
        <span class="muted">— <%= t('notification_rules.track_favorites_hint') %></span>
      </span>
    </label>
  <% end %>

  <%# One schedule block, reactive to the window select (above): with a window the
      cadence is derived (picker hidden, model forces it), without one the user
      picks freely. weekday shows for weekly/biweekly, monthday for monthly. %>
  <fieldset class="rule-fieldset flex flex-col gap-small">
    <legend><%= t('notification_rules.section_when') %></legend>
    <div class="rule-row flex gap-small">
      <label class="flex flex-col gap-xsmall" data-rule-form-target="cadenceField">
        <span><%= t('notification_rules.fields.cadence') %></span>
        <%= form.select :cadence, rule_cadence_options, {}, data: { 'rule-form-target': 'cadence', action: 'rule-form#update' } %>
      </label>
      <label class="flex flex-col gap-xsmall" data-rule-form-target="weekday">
        <span><%= t('notification_rules.fields.weekday') %></span>
        <%= form.select :weekday, rule_weekday_options %>
      </label>
      <label class="flex flex-col gap-xsmall" data-rule-form-target="monthday">
        <span><%= t('notification_rules.fields.monthday') %></span>
        <%= form.select :monthday, rule_monthday_options %>
      </label>
      <label class="flex flex-col gap-xsmall">
        <span><%= t('notification_rules.fields.time') %></span>
        <%= form.time_field :time_string, value: rule.time_string %>
      </label>
    </div>
  </fieldset>

  <fieldset class="rule-fieldset flex flex-col gap-small">
    <legend><%= t('notification_rules.section_channels') %></legend>
    <p class="muted rule-hint"><%= t('notification_rules.channels_hint') %></p>
    <label class="rule-check flex gap-small">
      <%= form.check_box :notify_push %>
      <span><%= t('notification_rules.fields.notify_push') %></span>
    </label>
    <% email_ready = MailConfig.configured? && current_user.email_address.present? %>
    <label class="<%= class_names('rule-check', 'flex', 'gap-small', 'rule-check--disabled': !email_ready) %>">
      <%= form.check_box :notify_email, disabled: !email_ready %>
      <span>
        <%= t('notification_rules.fields.notify_email') %>
        <% unless email_ready %>
          <span class="muted">— <%= t('notification_rules.email_unavailable') %></span>
        <% end %>
      </span>
    </label>
  </fieldset>

  <div class="flex gap-small">
    <%= form.submit t(rule.persisted? ? 'notification_rules.save_button' : 'notification_rules.create_button') %>
    <%= link_to t('notification_rules.new.cancel'), notification_rules_path, class: 'button-small button-ghost' %>
  </div>
<% end %>
