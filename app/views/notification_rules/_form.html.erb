<%# Shared by new + edit. form_with infers POST (create) vs PATCH (update) from
    the record. The saved filter (q/g/l/d) posts as top-level fields (read by the
    controller's filter_params, not nested under notification_rule).

    A plain form with an explicit Save — no autosave. The What/Where pickers are the
    SAME genre/location tree the events filter uses (tags/_genre_sheet, _location_sheet
    via the filter-sheets controller), with submit-on-apply OFF: picking a genre
    stages it into this form as a checked g[]/l[] input and commits only on Save.
    (Autosave existed to tame the old combobox's client-side chip drift; the tree is
    plain server-rendered checkboxes, so there's nothing to drift — see the redesign
    doc.) rule-form keys the schedule off the window select. %>
<%# .filter-sheets pulls in the same desktop dropdown-panel + mobile full-screen
    sheet CSS the events filter uses (keyed off that class). %>
<div class="rule-filter-picker filter-sheets"
     data-controller="filter-sheets"
     data-filter-sheets-submit-on-apply-value="false"
     data-filter-sheets-search-for-template-value="<%= t('events.filter.search_for', query: '%{query}') %>"
     data-filter-sheets-search-anything-value="<%= t('events.filter.search_anything') %>">
  <%# `filter` is the rule's saved filter (NotificationRulesController#filter_for). %>
  <%= form_with model: rule, class: 'rule-form account-form flex flex-col gap-medium',
        data: { controller: 'rule-form', 'rule-form-rhythms-value': NotificationRule::WINDOW_RHYTHM.to_json,
                'filter-sheets-target': 'form' } do |form| %>
    <% if rule.errors.any? %>
      <ul class="form-errors">
        <% rule.errors.full_messages.each { |m| %><li><%= m %></li><% } %>
      </ul>
    <% end %>

    <%# What this watches — the same trigger bar + tree sheets as the events filter,
        so the two read identically. The window (the filter's date) is a preset
        select (a recurring alert takes no custom range), and it also drives the
        schedule cadence below (rule-form#update). %>
    <fieldset class="rule-fieldset flex flex-col gap-medium">
      <legend><%= t('notification_rules.section_what') %></legend>

      <% what_terms  = filter.queries + filter.genres %>
      <% where_terms = filter.location_list.map { |loc| location_display(loc) } %>
      <div class="filter-sheets__bar">
        <%= render 'tags/filter_trigger', field: 'what',  icon: 'query',     terms: what_terms,  empty: t('events.filter.what') %>
        <%= render 'tags/filter_trigger', field: 'where', icon: 'locations', terms: where_terms, empty: t('events.filter.where') %>
      </div>

      <%# The sheets sit right under the bar so the desktop dropdown panel lands
          beneath its trigger. (Mobile sheets are fixed full-screen — order is moot.) %>
      <%= render 'tags/genre_sheet', filter: filter %>
      <%= render 'tags/location_sheet', filter: filter %>

      <%= select_tag 'd[]', options_for_select(rule_window_options, filter.date_ranges.first),
            include_blank: t('notification_rules.window_none'),
            data: { 'rule-form-target': 'window', action: 'rule-form#update' } %>
    </fieldset>

    <%# One schedule block, reactive to the window select (above): with a window the
        cadence is derived (picker hidden, model forces it), without one the user
        picks freely. weekday shows for weekly/biweekly, monthday for monthly. %>
    <fieldset class="rule-fieldset flex flex-col gap-small">
      <legend><%= t('notification_rules.section_when') %></legend>
      <%# No per-field labels — the values speak for themselves; aria-label keeps
          each control named for assistive tech. The time snaps to the quarter hour
          on blur (rule-form#snapTime), since the scheduler runs quarter-hourly. %>
      <div class="rule-row flex gap-small">
        <label class="flex flex-col gap-xsmall" data-rule-form-target="cadenceField">
          <%= form.select :cadence, rule_cadence_options, {}, data: { 'rule-form-target': 'cadence', action: 'rule-form#update' }, 'aria-label': t('notification_rules.fields.cadence') %>
        </label>
        <label class="flex flex-col gap-xsmall" data-rule-form-target="weekday">
          <%= form.select :weekday, rule_weekday_options, {}, 'aria-label': t('notification_rules.fields.weekday') %>
        </label>
        <label class="flex flex-col gap-xsmall" data-rule-form-target="monthday">
          <%= form.select :monthday, rule_monthday_options, {}, 'aria-label': t('notification_rules.fields.monthday') %>
        </label>
        <label class="flex flex-col gap-xsmall">
          <%= form.time_field :time_string, value: rule.time_string, 'aria-label': t('notification_rules.fields.time'), data: { action: 'change->rule-form#snapTime' } %>
        </label>
      </div>
    </fieldset>

    <%# In-app is the MASTER channel: unchecking it makes this a silent saved
        filter (never delivers), so push + email are forced off and disabled —
        client-side here (notify-channels controller) and server-side
        (NotificationRule#silence_other_channels). %>
    <fieldset class="rule-fieldset flex flex-col gap-small" data-controller="notify-channels">
      <legend><%= t('notification_rules.section_channels') %></legend>
      <p class="muted rule-hint"><%= t('notification_rules.channels_hint') %></p>
      <label class="rule-check flex gap-small">
        <%= form.check_box :notify_in_app, data: { 'notify-channels-target': 'master', action: 'notify-channels#sync' } %>
        <span><%= t('notification_rules.fields.notify_in_app') %></span>
      </label>
      <label class="rule-check rule-check--sub flex gap-small">
        <%= form.check_box :notify_push, data: { 'notify-channels-target': 'dependent' } %>
        <span><%= t('notification_rules.fields.notify_push') %></span>
      </label>
      <% email_ready = MailConfig.configured? && current_user.email_address.present? %>
      <%# Email has a second reason to be disabled (no address on file); data-locked
          keeps it off even when in-app is on, so the controller never re-enables it. %>
      <label class="<%= class_names('rule-check', 'rule-check--sub', 'flex', 'gap-small', 'rule-check--disabled': !email_ready) %>">
        <%= form.check_box :notify_email, disabled: !email_ready,
              data: { 'notify-channels-target': 'dependent', locked: !email_ready } %>
        <span>
          <%= t('notification_rules.fields.notify_email') %>
          <% unless email_ready %>
            <span class="muted">— <%= link_to t('notification_rules.email_unavailable'), settings_path %></span>
          <% end %>
        </span>
      </label>
    </fieldset>

    <%# Explicit Save (the form commits everything at once); "Löschen" removes the
        rule. Delete is a turbo_method link (not button_to, which would nest a form). %>
    <div class="flex gap-small rule-actions">
      <%= form.submit t('notification_rules.save_button'), class: 'button-small primary' %>
      <% if rule.persisted? %>
        <%= link_to t('notification_rules.delete'), notification_rule_path(rule),
              class: 'button-small button-ghost danger',
              data: { turbo_method: :delete, turbo_confirm: t('notification_rules.delete_confirm') } %>
      <% end %>
    </div>
  <% end %>
</div>
