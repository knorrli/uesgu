<% content_for :title, t('notification_rules.edit.title') %>

<%# The editor autosaves: the form lives in this turbo frame, so each change
    re-renders the frame in place with the canonical server state — including the
    title (the rule name is always the derived filter description, rendered
    server-side here, no client mirror). "Fertig"/"Löschen" break out of the
    frame to navigate. %>
<div class="notification-rules flex flex-col gap-large">
  <%= turbo_frame_tag 'rule_editor' do %>
    <header class="flex flex-col gap-small">
      <p class="muted rule-kicker"><%= t('notification_rules.edit.title') %></p>
      <h1><%= @rule.display_name %></h1>
      <p class="muted"><%= t('notification_rules.edit.intro') %></p>
    </header>

    <%# Heads-up: another rule already covers this exact filter. Non-blocking —
        editing is allowed to produce a duplicate (only the events-page bell
        dedupes) — so it's an info notice, not an error, with a link to that rule. %>
    <% if @duplicate_of %>
      <p class="rule-notice">
        <%= t('notification_rules.duplicate_edit') %>
        <%= link_to @duplicate_of.display_name, edit_notification_rule_path(@duplicate_of), data: { turbo_frame: '_top' } %>
      </p>
    <% end %>

    <%= render 'form', rule: @rule, filter: @filter, matches_favorites: @matches_favorites %>
  <% end %>
</div>
