<% content_for :title, t('notification_rules.edit.title') %>

<%# The rule name is always the filter description; show it live as the page
    title so edits to the filter are visibly reflected in real time. The
    rule-name controller wraps both the header (preview) and the form (chips +
    window), listening for their change events. %>
<div class="notification-rules flex flex-col gap-large" data-controller="rule-name"
     data-rule-name-fallback-value="<%= t('notification_rules.summary.scope_all') %>"
     data-action="tag-picker:change->rule-name#refresh change->rule-name#refresh">
  <header class="flex flex-col gap-small">
    <p class="muted rule-kicker"><%= t('notification_rules.edit.title') %></p>
    <h1 data-rule-name-target="preview"><%= @rule.display_name %></h1>
    <p class="muted"><%= t('notification_rules.edit.intro') %></p>
  </header>

  <%= render 'form', rule: @rule, filter: @filter, matches_favorites: @matches_favorites %>
</div>
