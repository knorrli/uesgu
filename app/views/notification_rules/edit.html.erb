<% content_for :title, t('notification_rules.edit.title') %>

<%# A plain edit page (no autosave / turbo frame): the form commits on Save and
    redirects to the Saved filters list. The title is the derived filter
    description, rendered server-side. %>
<%# rule-title live-updates the h1 from the picker as you edit (mirrors
    NotificationRule#describe); the server re-derives the authoritative name on Save. %>
<div class="notification-rules flex flex-col gap-large"
     data-controller="rule-title"
     data-rule-title-scope-all-value="<%= t('notification_rules.summary.scope_all') %>"
     data-rule-title-added-label-value="<%= t('notification_rules.type.added') %>"
     data-action="change->rule-title#update">
  <header class="flex flex-col gap-small">
    <p class="muted rule-kicker"><%= t('notification_rules.edit.title') %></p>
    <h1 data-rule-title-target="title"><%= @rule.display_name %></h1>
    <p class="muted"><%= t('notification_rules.edit.intro') %></p>
  </header>

  <%# Heads-up: another rule already covers this exact filter. Non-blocking —
      editing is allowed to produce a duplicate (only the events-page ★ dedupes) —
      so it's an info notice, not an error, with a link to that rule. %>
  <% if @duplicate_of %>
    <p class="rule-notice">
      <%= t('notification_rules.duplicate_edit') %>
      <%= link_to @duplicate_of.display_name, edit_notification_rule_path(@duplicate_of) %>
    </p>
  <% end %>

  <%= render 'form', rule: @rule, filter: @filter %>
</div>
