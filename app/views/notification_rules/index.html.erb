<% content_for :title, t('notification_rules.title') %>

<div class="notification-rules flex flex-col gap-large">
  <header class="flex flex-col gap-small">
    <h1><%= t('notification_rules.title') %></h1>
    <p class="muted"><%= t('notification_rules.intro') %></p>
  </header>

  <% if @rules.empty? %>
    <p class="empty-state"><%= t('notification_rules.empty_html', link: link_to(t('notification_rules.empty_link'), events_path)).html_safe %></p>
  <% else %>
    <ul class="rule-list flex flex-col gap-medium">
      <% @rules.each do |rule| %>
        <%# A saved filter is "silent" (a pure interest/scope) when its in-app
            channel is off — no digest is ever created. Notifying ones get the
            accent border + their schedule/channels; both kinds live in one list. %>
        <li class="<%= class_names('rule-card', 'flex', 'flex-col', 'gap-small', 'rule-card--silent': !rule.notifying?) %>">
          <div class="flex flex-col gap-xsmall">
            <%# The name already encodes the type (… · Neue Events / … · Diese Woche),
                so no separate type badge or repeated summary line is needed. %>
            <span class="rule-card__name"><%= rule.display_name %></span>
            <span class="muted rule-card__summary">
              <%= rule.notifying? ? rule_schedule_summary(rule) : t('notification_rules.silent') %>
            </span>
          </div>

          <%# Channels, read-only — the editor is where they're changed. %>
          <% if rule.notifying? %>
            <div class="rule-card__chips flex gap-xsmall">
              <% rule_channels(rule).each do |label| %>
                <span class="chip"><%= label %></span>
              <% end %>
            </div>
          <% end %>

          <div class="rule-card__actions flex gap-small">
            <%# Apply copies the saved filter into the events URL (the link is then
                severed — the main page stays ephemeral). It's navigation, so a link. %>
            <%= link_to t('notification_rules.apply'),
                  events_path(q: rule.queries, g: rule.genres, l: rule.location_list, s: rule.style_list, d: rule.date_ranges),
                  class: 'button-small' %>
            <% if rule.notifying? %>
              <%= button_to t('notification_rules.fire_now'), fire_notification_rule_path(rule), class: 'button-small button-ghost' %>
            <% end %>
            <%= button_to t('notification_rules.delete'), notification_rule_path(rule), method: :delete,
                  class: 'button-small button-ghost danger', data: { turbo_confirm: t('notification_rules.delete_confirm') } %>
            <%= link_to t('notification_rules.edit_button'), edit_notification_rule_path(rule), class: 'text-link' %>
          </div>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>
