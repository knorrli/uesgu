<% content_for :title, t('inbox.title') %>

<div class="flex flex-col gap-large">
  <%= render layout: "shared/page_header", locals: { back_path: root_path, back_label: t('nav.events') } do %>
    <div class="notifications-header flex justify-between align-center gap-medium">
      <h1><%= t('inbox.title') %></h1>
      <%# Ungelesen | Gelesen — same flat-text toggle as the list/calendar switcher,
          top-right. Hidden until the user has at least one notification (no point
          offering a read archive on a never-used inbox). %>
      <% if @read_count.positive? || @unread_count.positive? %>
        <nav class="segmented" aria-label="<%= t('notifications.index.view_label') %>">
          <%= link_to t('notifications.index.tab_unread'), notifications_path,
                class: class_names(active: !@show_read) %>
          <%= link_to t('notifications.index.tab_read'), notifications_path(read: 1),
                class: class_names(active: @show_read) %>
        </nav>
      <% end %>
    </div>
  <% end %>

  <% if @notifications.any? %>
    <ul class="notifications">
    <% @notifications.each do |notification| %>
      <li class="<%= class_names('notification', unread: !notification.read?) %>">
        <%= link_to notification_path(notification) do %>
          <% name = notification.saved_filter&.display_name.presence || notification.title.presence || t('notifications.index.fallback_name') %>
          <span class="notification__name">
            <%= name %>
            <% unless notification.read? %><span class="badge"><%= t('notifications.index.unread_badge') %></span><% end %>
          </span>
          <%# Count then date, so the fixed-width date sits flush right and the
              dates align across rows regardless of the count's length. %>
          <span class="notification__meta">
            <%= t('notifications.index.event_count', count: @event_counts[notification.id]) %>
            <span class="sep" aria-hidden="true">·</span>
            <span class="notification__dates"><%= l notification.period_start.to_date %> – <%= l notification.period_end.to_date %></span>
          </span>
        <% end %>
      </li>
    <% end %>
    </ul>
  <% elsif @show_read %>
    <p class="empty-state"><%= t('notifications.index.none_read') %></p>
  <% elsif @read_count.zero? %>
    <p class="empty-state"><%= t('notifications.index.empty') %></p>
  <% else %>
    <p class="empty-state"><%= t('notifications.index.all_read') %></p>
  <% end %>
</div>
