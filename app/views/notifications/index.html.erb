<% content_for :title, "Notifications" %>

<h1>Notifications</h1>

<% if @notifications.empty? %>
  <p class="empty-state">No notifications yet. We'll round up newly added events for you here.</p>
<% else %>
  <ul class="notifications">
    <% @notifications.each do |notification| %>
      <li class="<%= class_names('notification', unread: !notification.read?) %>">
        <%= link_to notification_path(notification) do %>
          <span class="notification__period">
            <%= l notification.period_start.to_date %> – <%= l notification.period_end.to_date %>
          </span>
          <span class="notification__meta">
            <%= pluralize notification.events.count, 'new event' %>
            <% unless notification.read? %><span class="badge">New</span><% end %>
          </span>
        <% end %>
      </li>
    <% end %>
  </ul>
<% end %>
