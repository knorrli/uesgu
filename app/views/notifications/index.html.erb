<% content_for :title, t('notifications.index.title') %>

<h1><%= t('notifications.index.title') %></h1>

<% if @notifications.empty? %>
  <p class="empty-state"><%= t('notifications.index.empty') %></p>
<% else %>
  <ul class="notifications">
    <% @notifications.each do |notification| %>
      <li class="<%= class_names('notification', unread: !notification.read?) %>">
        <%= link_to notification_path(notification) do %>
          <% name = notification.notification_rule&.display_name.presence || notification.title.presence || t('notifications.index.fallback_name') %>
          <span class="notification__name">
            <%= name %>
            <% unless notification.read? %><span class="badge"><%= t('notifications.index.unread_badge') %></span><% end %>
          </span>
          <%# Count then date, so the fixed-width date sits flush right and the
              dates align across rows regardless of the count's length. %>
          <span class="notification__meta">
            <%= t('notifications.index.event_count', count: @event_counts[notification.id]) %>
            <span class="sep" aria-hidden="true">·</span>
            <span class="notification__dates"><%= l notification.period_start.to_date %> – <%= l notification.period_end.to_date %></span>
          </span>
        <% end %>
      </li>
    <% end %>
  </ul>
<% end %>
