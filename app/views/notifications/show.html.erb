<% content_for :title, t('notifications.show.title') %>

<%= link_to t('notifications.show.back'), notifications_path, class: "back-link" %>

<header class="page-header">
  <h1><%= t('notifications.show.title') %></h1>
  <p class="muted"><%= l @notification.period_start.to_date %> – <%= l @notification.period_end.to_date %></p>
</header>

<div class="segmented">
  <%= link_to t('notifications.show.all'), notification_path(@notification), class: class_names(active: !@only_relevant) %>
  <%= link_to t('notifications.show.relevant'), notification_path(@notification, relevant: 1), class: class_names(active: @only_relevant) %>
</div>

<% if @events.none? %>
  <p class="empty-state">
    <%= @only_relevant ? t('notifications.show.empty_relevant') : t('notifications.show.empty_all') %>
  </p>
<% else %>
  <% @events.group_by(&:start_date).each do |date, events| %>
    <section class="event-day <%= class_names(past: date < Date.current.beginning_of_day) %>">
      <h2 class="event-day__heading"><%= l date, format: :detailed %></h2>
      <% events.each do |event| %>
        <article class="event-card">
          <% if event.start_time.present? %>
            <span class="event-card__time"><%= l event.start_time, format: :time %></span>
          <% end %>
          <h3 class="event-card__title"><%= link_to event.title, event.url, target: :blank %></h3>
          <% if event.subtitle.present? %>
            <%= simple_format(event.subtitle, class: "muted") %>
          <% end %>
          <div class="event-card__tags">
            <% event.locations.each do |location| %>
              <span class="tag"><span class="<%= tag_icon_class(context: Location.type_for(location.name)) %>"></span> <%= location %></span>
            <% end %>
            <% event.styles.each do |style| %>
              <span class="tag"><span class="<%= tag_icon_class(context: 'styles') %>"></span> <%= style %></span>
            <% end %>
          </div>
        </article>
      <% end %>
    </section>
  <% end %>
<% end %>
