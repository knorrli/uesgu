<% name = @notification.saved_filter&.display_name.presence || @notification.title.presence || t('notifications.show.title') %>
<% content_for :title, name %>

<%= link_to t('notifications.show.back'), notifications_path, class: "back-link" %>

<header class="page-header">
  <h1><%= name %></h1>
  <p class="muted"><%= l @notification.period_start.to_date %> – <%= l @notification.period_end.to_date %></p>
</header>

<% if @events.none? %>
  <p class="empty-state"><%= t('notifications.show.empty_all') %></p>
<% else %>
  <div class="event-list flex flex-col gap-xlarge">
    <% @events.group_by(&:start_date).each do |date, events| %>
      <div class="date-events flex flex-col gap-medium <%= class_names(past: date < Date.current.beginning_of_day) %>">
        <h2 class="date"><%= l date, format: :detailed %></h2>
        <%= render 'events/venue_groups', events: events, filter: nil, interactive: true %>
      </div>
    <% end %>
  </div>
<% end %>
