<% content_for :title, "New events" %>

<div class="content flex flex-col gap-large">
  <p><%= link_to "← All notifications", notifications_path %></p>

  <header class="flex flex-col gap-small">
    <h1>New events</h1>
    <p class="muted"><%= l @notification.period_start.to_date %> – <%= l @notification.period_end.to_date %></p>
  </header>

  <div class="flex gap-small" role="group" aria-label="Filter notification">
    <%= link_to "All new events", notification_path(@notification),
          class: class_names(:tag, active: !@only_relevant) %>
    <%= link_to "Only my favorites", notification_path(@notification, relevant: 1),
          class: class_names(:tag, active: @only_relevant) %>
  </div>

  <% if @events.none? %>
    <p>
      <%= @only_relevant ? "No new events matched your favorite locations or styles this period." : "No new events this period." %>
    </p>
  <% else %>
    <section class="flex flex-col gap-xlarge">
      <% @events.group_by(&:start_date).each do |date, events| %>
        <div class="flex flex-col gap-small date-events <%= class_names(past: date < Date.current.beginning_of_day) %>">
          <h2 class="date"><%= l date, format: :detailed %></h2>
          <div class="flex flex-col gap-medium">
            <% events.each do |event| %>
              <article class="event flex flex-col gap-small">
                <% if event.start_time.present? %>
                  <h5 class="event-time"><%= l event.start_time, format: :time %></h5>
                <% end %>
                <h3 class="event-title"><%= link_to event.title, event.url, target: :blank %></h3>
                <% if event.subtitle.present? %>
                  <h4 class="event-subtitle"><%= simple_format(event.subtitle) %></h4>
                <% end %>
                <div class="flex gap-small wrap">
                  <% event.locations.each do |location| %>
                    <span class="tag"><span class="<%= tag_icon_class(context: 'locations') %>"></span> <%= location %></span>
                  <% end %>
                  <% event.styles.each do |style| %>
                    <span class="tag"><span class="<%= tag_icon_class(context: 'styles') %>"></span> <%= style %></span>
                  <% end %>
                </div>
              </article>
            <% end %>
          </div>
        </div>
      <% end %>
    </section>
  <% end %>
</div>
