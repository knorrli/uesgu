<% content_for :title, t('auth.signup_title') %>
<div class="flex flex-col gap-medium">
  <%= render layout: "shared/page_header" do %>
    <h1><%= t('auth.signup_title') %></h1>
  <% end %>

  <%= form_with model: @user, url: registration_path, class: 'account-form flex flex-col align-stretch gap-medium' do |form| %>
    <% if @user.errors.any? %>
      <ul class="form-errors">
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    <% end %>

    <div class="flex flex-col gap-small">
      <label class="flex flex-col gap-small">
        <span class="field-label"><%= t('auth.invite_label') %></span>
        <%# Hint between label and input → reading order label → hint → input. %>
        <span class="muted"><%= t('auth.invite_hint') %></span>
        <%= text_field_tag :invitation_code, @invite_code, required: true, autocomplete: "off",
              autocapitalize: "characters", spellcheck: false %>
      </label>
    </div>

    <label class="flex flex-col gap-small">
      <span class="field-label"><%= t('auth.username') %></span>
      <%= form.text_field :username, required: true, autofocus: @invite_code.blank?, autocomplete: "username" %>
    </label>
    <label class="flex flex-col gap-small">
      <span class="field-label"><%= t('auth.password') %></span>
      <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72 %>
    </label>
    <label class="flex flex-col gap-small">
      <span class="field-label"><%= t('auth.password_confirmation') %></span>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72 %>
    </label>

    <%= form.submit t('auth.signup_submit') %>
  <% end %>

  <p><%= t('auth.have_account_html', link: link_to(t('auth.log_in_link'), new_session_path)) %></p>
</div>
