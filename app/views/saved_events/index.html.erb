<% content_for :title, t('saved_events.title') %>
<%# Same list/calendar-per-session-state caveat as the main programme: opt out of
    Turbo's snapshot cache so the saved view never flickers between views. %>
<% content_for :head do %><meta name="turbo-cache-control" content="no-cache"><% end %>

<div class="flex flex-col gap-large">
  <%= render layout: "shared/page_header", locals: { back_path: root_path, back_label: t('nav.events') } do %>
    <h1><%= t('saved_events.title') %></h1>
    <%# List / Kalender switcher on its own row below the title (left-aligned, not
        inline beside it) so a long title can't clip it on narrow screens — mirrors
        the notifications header. Only appears once there's something to toggle
        between; a brand-new shelf just shows the empty state. %>
    <% if @any_saved %><%= render 'events/view_switcher', view: @view %><% end %>
  <% end %>

  <%# Day-of reminder opt-in: a property of the saved-shows feature (it nudges you
      about the shows listed here), so it lives on this page rather than Settings.
      Only shown once there's something to be reminded about. Auto-saves in the
      background (reminder controller); no Save button. %>
  <% if @any_saved %>
    <div class="saved-reminder" data-controller="reminder">
      <label class="saved-reminder__toggle flex gap-small align-center">
        <%= check_box_tag 'event_reminders', '1', current_user.event_reminders?,
              data: { reminder_target: 'checkbox', action: 'reminder#toggle' } %>
        <span><%= t('saved_events.reminders_label') %></span>
      </label>
      <p class="muted saved-reminder__hint"><%= t('saved_events.reminders_hint') %></p>
    </div>
  <% end %>

  <% if !@any_saved %>
    <p class="empty-state"><%= t('saved_events.empty') %></p>
  <% elsif @view == 'calendar' %>
    <%# These shows are all saved already, so the per-day bookmark marker would
        flag every day — suppress it; the interest dot still applies. %>
    <%= render 'events/calendar', events: @events, show_saved_markers: false %>
  <% elsif @events.empty? %>
    <%# Has saved shows, but none upcoming — the calendar still holds the past ones. %>
    <p class="empty-state"><%= t('saved_events.none_upcoming') %></p>
  <% else %>
    <div class="event-list flex flex-col gap-xlarge">
      <% @events.group_by(&:start_date).each do |date, events| %>
        <div class="date-events flex flex-col gap-medium">
          <h2 class="date"><%= l date, format: :detailed %></h2>
          <%# interactive: the venue/style tags are follow-toggles here too, same as
              the main programme — clicking a name follows/unfollows it (not a filter
              link), so the behaviour is consistent everywhere. %>
          <%= render 'events/venue_groups', events: events, filter: nil, interactive: true %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
