<% content_for :title, t('saved_filters.edit.title') %>

<%# A plain edit page (no autosave / turbo frame): the form commits on Save and
    redirects to the Saved filters list. The title is the derived filter
    description, rendered server-side. %>
<%# saved-filter-title live-updates the h1 from the picker as you edit (mirrors
    SavedFilter#describe); the server re-derives the authoritative name on Save. %>
<div class="saved-filters flex flex-col gap-large"
     data-controller="saved-filter-title"
     data-saved-filter-title-scope-all-value="<%= t('saved_filters.summary.scope_all') %>"
     data-saved-filter-title-added-label-value="<%= t('saved_filters.type.added') %>"
     data-action="change->saved-filter-title#update">
  <%= render layout: "shared/page_header", locals: { back_path: saved_filters_path, back_label: t("saved_filters.edit.back") } do %>
    <p class="muted saved-filter-kicker"><%= t('saved_filters.edit.title') %></p>
    <h1 data-saved-filter-title-target="title"><%= @rule.display_name %></h1>
  <% end %>

  <%# Heads-up: another rule already covers this exact filter. Non-blocking —
      editing is allowed to produce a duplicate (only the events-page ★ dedupes) —
      so it's an info notice, not an error, with a link to that rule. %>
  <% if @duplicate_of %>
    <p class="saved-filter-notice">
      <%= t('saved_filters.duplicate_edit') %>
      <%= link_to @duplicate_of.display_name, edit_saved_filter_path(@duplicate_of) %>
    </p>
  <% end %>

  <%= render 'form', rule: @rule, filter: @filter %>
</div>
