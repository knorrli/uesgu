<% content_for :title, t('saved_filters.title') %>

<div class="saved-filters flex flex-col gap-large">
  <%= render layout: "shared/page_header", locals: { back_path: root_path, back_label: t('nav.events') } do %>
    <h1><%= t('saved_filters.title') %></h1>
  <% end %>

  <% if @rules.empty? %>
    <p class="empty-state"><%= t('saved_filters.empty_html', link: link_to(t('saved_filters.empty_link'), events_path)).html_safe %></p>
  <% else %>
    <ul class="saved-filter-list flex flex-col">
      <% @rules.each do |rule| %>
        <%# A saved filter is "silent" (a pure interest/scope) when its in-app
            channel is off — no digest is ever created. Notifying ones get the
            accent border + their schedule/channels; both kinds live in one list. %>
        <li class="<%= class_names('saved-filter-card', 'flex', 'flex-col', 'gap-small', 'saved-filter-card--silent': !rule.notifying?) %>">
          <div class="flex flex-col gap-xsmall">
            <%# The name already encodes the type (… · Neue Events / … · Diese Woche),
                so no separate type badge or repeated summary line is needed. The
                name itself links to the editor — the card's primary action — so the
                button row below stays a clean action cluster (no lone Edit link). %>
            <%= link_to rule.display_name, edit_saved_filter_path(rule), class: 'saved-filter-card__name' %>
            <span class="muted saved-filter-card__summary">
              <%= rule.notifying? ? rule_schedule_summary(rule) : t('saved_filters.silent') %>
            </span>
          </div>

          <%# Channels, read-only — the editor is where they're changed. %>
          <% if rule.notifying? %>
            <div class="saved-filter-card__chips flex gap-xsmall">
              <% rule_channels(rule).each do |label| %>
                <span class="chip"><%= label %></span>
              <% end %>
            </div>
          <% end %>

          <div class="saved-filter-card__actions flex gap-small">
            <%# Apply copies the saved filter into the events URL (the link is then
                severed — the main page stays ephemeral). It's navigation, so a link. %>
            <%= link_to t('saved_filters.apply'),
                  events_path(q: rule.queries, g: rule.genres, l: rule.location_list, d: rule.date_ranges),
                  class: 'button-small' %>
            <% if rule.notifying? %>
              <%= button_to t('saved_filters.fire_now'), fire_saved_filter_path(rule), class: 'button-small' %>
            <% end %>
            <%= button_to t('saved_filters.delete'), saved_filter_path(rule), method: :delete,
                  class: 'button-small danger', data: { turbo_confirm: t('saved_filters.delete_confirm') } %>
          </div>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>
