<div class="flex flex-col gap-medium">
  <h1>Log in</h1>

  <%= form_with url: session_path, class: 'account-form flex flex-col align-stretch gap-medium' do |form| %>
    <%= form.text_field :username, required: true, autofocus: true, autocomplete: "username", placeholder: "Username", value: params[:username] %>
    <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Password", maxlength: 72 %>
    <%= form.submit "Log in" %>
  <% end %>

  <p>No account yet? <%= link_to "Sign up", signup_path %>.</p>
</div>
