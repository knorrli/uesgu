<% content_for :title, t('auth.login_title') %>
<div class="flex flex-col gap-medium">
  <h1><%= t('auth.login_title') %></h1>

  <%= form_with url: session_path, class: 'account-form flex flex-col align-stretch gap-medium' do |form| %>
    <label class="flex flex-col gap-small">
      <span class="field-label"><%= t('auth.username') %></span>
      <%= form.text_field :username, required: true, autofocus: true, autocomplete: "username", value: params[:username] %>
    </label>
    <label class="flex flex-col gap-small">
      <span class="field-label"><%= t('auth.password') %></span>
      <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72 %>
    </label>
    <%= form.submit t('auth.login_submit') %>
  <% end %>

  <p><%= t('auth.no_account_html', link: link_to(t('auth.sign_up_link'), signup_path)) %></p>
</div>
