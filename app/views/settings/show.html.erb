<div class="flex flex-col gap-large">
  <h1><%= t('settings.title') %></h1>

  <%= form_with model: @user, url: settings_path, method: :patch, class: 'account-form flex flex-col gap-large' do |form| %>
    <% if @user.errors.any? %>
      <ul class="form-errors">
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    <% end %>

    <section class="flex flex-col gap-small">
      <h2><%= t('settings.notifications_heading') %></h2>
      <label class="flex flex-col gap-small">
        <span><%= t('settings.frequency_label') %></span>
        <%= form.select :notification_frequency, User::FREQUENCIES.map { |f| [t("frequencies.#{f}"), f] } %>
      </label>
    </section>

    <section class="flex flex-col gap-small">
      <h2><%= t('settings.language_heading') %></h2>
      <%= form.select :locale,
            I18n.available_locales.map { |l| [t("languages.#{l}"), l] },
            include_blank: t('settings.language_auto') %>
    </section>

    <section class="flex flex-col gap-small">
      <h2><%= t('settings.favorite_locations_heading') %></h2>
      <p><%= t('settings.favorite_locations_hint') %></p>
      <div class="location-picker"><%= render 'location_picker', user: @user %></div>
    </section>

    <section class="flex flex-col gap-small">
      <h2><%= t('settings.favorite_styles_heading') %></h2>
      <div class="chips flex flex-row wrap gap-small">
        <%= form.collection_check_boxes :style_list, Style.order(name: :asc), :name, :name do |b| %>
          <label class="tag"><%= b.check_box %> <%= b.text %></label>
        <% end %>
      </div>
    </section>

    <section class="flex flex-col gap-small">
      <h2><%= t('settings.email_heading') %> <span class="muted"><%= t('settings.email_optional') %></span></h2>
      <p><%= t('settings.email_hint') %></p>
      <%= form.email_field :email_address, autocomplete: "email", placeholder: t('settings.email_placeholder') %>
    </section>

    <section class="flex flex-col gap-small">
      <h2><%= t('settings.password_heading') %></h2>
      <p><%= t('settings.password_hint') %></p>
      <%= form.password_field :password, autocomplete: "new-password", placeholder: t('settings.new_password'), maxlength: 72 %>
      <%= form.password_field :password_confirmation, autocomplete: "new-password", placeholder: t('settings.confirm_new_password'), maxlength: 72 %>
    </section>

    <%= form.submit t('settings.save') %>
  <% end %>

  <section class="flex flex-col gap-small">
    <h2><%= t('settings.delete_account_heading') %></h2>
    <p><%= t('settings.delete_account_hint') %></p>
    <%= button_to t('settings.delete_account'), registration_path, method: :delete, class: "button delete",
          data: { turbo_confirm: t('settings.delete_account_confirm') } %>
  </section>
</div>
