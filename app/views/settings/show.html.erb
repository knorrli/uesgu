<div class="settings flex flex-col gap-large">
  <%# Logout is a page-level action (top-right), not its own section — rare
      account plumbing, one tap, no heading/hint needed. %>
  <div class="flex justify-between align-center wrap gap-medium">
    <h1><%= t('settings.title') %></h1>
    <%= button_to t('settings.signout_button'), session_path, method: :delete, class: "button-small button-ghost" %>
  </div>

  <% if @user.errors.any? %>
    <ul class="form-errors">
      <% @user.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  <% end %>

  <%# ── Account ─────────────────────────────────────────────────────────────
      One form covers everything stored on the user: language, email and
      password. The controller permits all of these in a single update, so a
      single Save button keeps the page from sprouting a button per block. %>
  <section class="settings-section">
    <h2><%= t('settings.account_heading') %></h2>

    <%= form_with model: @user, url: settings_path, method: :patch, class: 'account-form flex flex-col gap-medium' do |form| %>
      <div class="flex flex-col gap-small">
        <span class="field-label"><%= t('auth.username') %></span>
        <span><%= @user.username %></span>
      </div>

      <label class="flex flex-col gap-small">
        <span class="field-label"><%= t('settings.language_heading') %></span>
        <%= form.select :locale,
              I18n.available_locales.map { |l| [t("languages.#{l}"), l] },
              include_blank: t('settings.language_auto') %>
      </label>

      <fieldset class="settings-field flex flex-col gap-small">
        <legend><%= t('settings.email_heading') %></legend>
        <%= form.email_field :email_address, autocomplete: "email", placeholder: t('settings.email_placeholder') %>
        <%# One muted line below the field: optional + why + the third-party
            disclosure (the address goes to resend.com). Inline at the entry point. %>
        <p class="muted"><%= t('settings.email_hint') %></p>
      </fieldset>

      <fieldset class="settings-field flex flex-col gap-small">
        <legend><%= t('settings.password_heading') %></legend>
        <%= form.password_field :password, autocomplete: "new-password", placeholder: t('settings.new_password'), maxlength: 72 %>
        <%= form.password_field :password_confirmation, autocomplete: "new-password", placeholder: t('settings.confirm_new_password'), maxlength: 72 %>
        <p class="muted"><%= t('settings.password_hint') %></p>
      </fieldset>

      <%= form.submit t('settings.save') %>
    <% end %>
  </section>

  <%# ── Notifications on this device ─────────────────────────────────────────
      Per-device web push opt-in + a self-test. Installing the app now lives in
      the top nav (it targets logged-out users too), so it's no longer here. The
      whole section renders only when VAPID keys are configured; the push
      controller handles the unsupported / denied / needs-install states. %>
  <% if WebPushConfig.configured? %>
    <section class="settings-section">
      <h2><%= t('settings.notifications_heading') %></h2>

      <div class="flex flex-col gap-small"
           data-controller="push"
           data-push-vapid-public-key-value="<%= WebPushConfig.public_key %>"
           data-push-label-on-value="<%= t('settings.push_disable') %>"
           data-push-label-off-value="<%= t('settings.push_enable') %>"
           data-push-status-on-value="<%= t('settings.push_status_on') %>"
           data-push-status-off-value="<%= t('settings.push_status_off') %>"
           data-push-status-denied-value="<%= t('settings.push_status_denied') %>">
        <p class="muted"><%= t('settings.push_hint') %></p>
        <p class="muted" data-push-target="status"><%= t('settings.push_status_off') %></p>
        <div class="settings-actions">
          <button type="button" data-push-target="button" data-action="push#toggle">
            <%= t('settings.push_enable') %>
          </button>
          <button type="button" hidden data-push-target="testButton" data-action="push#sendTest">
            <%= t('settings.push_test') %>
          </button>
        </div>
        <p class="muted" hidden data-push-target="unsupported"><%= t('settings.push_unsupported') %></p>
        <%# iOS exposes the Push API only to an installed home-screen app, so
            there we point the user at installing first rather than saying
            "unsupported". %>
        <p class="muted" hidden data-push-target="installFirst"><%= t('settings.push_install_first') %></p>
      </div>
    </section>
  <% end %>

  <%# ── Delete account ──────────────────────────────────────────────────── %>
  <section class="settings-section">
    <h2><%= t('settings.delete_account_heading') %></h2>
    <p><%= t('settings.delete_account_hint') %></p>
    <%= button_to t('settings.delete_account'), registration_path, method: :delete, class: "button delete",
          data: { turbo_confirm: t('settings.delete_account_confirm') } %>
  </section>
</div>
