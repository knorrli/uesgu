<div class="flex flex-col gap-large">
  <h1>Settings</h1>

  <%= form_with model: @user, url: settings_path, method: :patch, class: 'account-form flex flex-col gap-large' do |form| %>
    <% if @user.errors.any? %>
      <ul class="form-errors">
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    <% end %>

    <section class="flex flex-col gap-small">
      <h2>Notifications</h2>
      <label class="flex flex-col gap-small">
        <span>How often should we tell you about new events?</span>
        <%= form.select :notification_frequency, User::FREQUENCIES.map { |f| [f.capitalize, f] } %>
      </label>
    </section>

    <section class="flex flex-col gap-small">
      <h2>Favorite locations</h2>
      <p>Get notified about events at these places.</p>
      <div class="chips flex flex-row wrap gap-small">
        <%= form.collection_check_boxes :location_list, available_tags(context: :locations), :name, :name do |b| %>
          <label class="tag"><%= b.check_box %> <%= b.text %></label>
        <% end %>
      </div>
    </section>

    <section class="flex flex-col gap-small">
      <h2>Favorite styles</h2>
      <div class="chips flex flex-row wrap gap-small">
        <%= form.collection_check_boxes :style_list, Style.order(name: :asc), :name, :name do |b| %>
          <label class="tag"><%= b.check_box %> <%= b.text %></label>
        <% end %>
      </div>
    </section>

    <section class="flex flex-col gap-small">
      <h2>Email <span class="muted">(optional)</span></h2>
      <p>Only needed if you want password reset or email digests later.</p>
      <%= form.email_field :email_address, autocomplete: "email", placeholder: "you@example.com" %>
    </section>

    <section class="flex flex-col gap-small">
      <h2>Change password</h2>
      <p>Leave blank to keep your current password.</p>
      <%= form.password_field :password, autocomplete: "new-password", placeholder: "New password", maxlength: 72 %>
      <%= form.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Confirm new password", maxlength: 72 %>
    </section>

    <%= form.submit "Save settings" %>
  <% end %>

  <section class="flex flex-col gap-small">
    <h2>Delete account</h2>
    <p>This permanently removes your account and favorites.</p>
    <%= button_to "Delete my account", registration_path, method: :delete, class: "button delete",
          data: { turbo_confirm: "Permanently delete your account? This cannot be undone." } %>
  </section>
</div>
