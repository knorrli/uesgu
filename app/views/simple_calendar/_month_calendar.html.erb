<%# Overrides simple_calendar's default month template so the month title + nav
    and the list/calendar view switcher share one toolbar row. Table rendering is
    unchanged from the gem. %>
<div class="simple-calendar">
  <%# Month title + nav only; the list/calendar switcher lives on its own row in
      index.html.erb so it stays put and the month title aligns with the list's
      first date header. %>
  <div class="calendar-heading flex align-baseline wrap justify-between gap-medium">
    <time datetime="<%= start_date.strftime('%Y-%m') %>" class="calendar-title"><%= t('date.month_names')[start_date.month] %> <%= start_date.year %></time>
    <nav class="flex gap-medium">
      <%= link_to t('simple_calendar.previous', default: 'Previous'), calendar_nav_path(calendar.url_for_previous_view), class: 'text-link' %>
      <%= link_to t('simple_calendar.today', default: 'Today'), calendar_nav_path(calendar.url_for_today_view), class: 'text-link' %>
      <%= link_to t('simple_calendar.next', default: 'Next'), calendar_nav_path(calendar.url_for_next_view), class: 'text-link' %>
    </nav>
  </div>

  <table class="table table-striped">
    <thead>
      <tr>
        <% date_range.slice(0, 7).each do |day| %>
          <th><%= t('date.abbr_day_names')[day.wday] %></th>
        <% end %>
      </tr>
    </thead>

    <tbody>
      <% date_range.each_slice(7) do |week| %>
        <tr>
          <% week.each do |day| %>
            <%= content_tag :td, class: calendar.td_classes_for(day) do %>
              <% instance_exec(day, calendar.sorted_events_for(day), &passed_block) %>
            <% end %>
          <% end %>
        </tr>
        <%# The events page expands a day inline (URL state): render its detail as
            a full-width row right under the week that holds it. Harmless on any
            other month_calendar — @open_day is only set there. %>
        <% if @open_day && week.include?(@open_day) %>
          <tr class="day-detail-row">
            <td colspan="7">
              <%= render 'events/day_detail', date: @open_day, events: @open_day_events, filter: @filter %>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>
