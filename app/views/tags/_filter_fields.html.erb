<%# Shared What + Where fields for the events filter (app/views/events/_filter)
    and the rule editor (app/views/notification_rules/_form), so the two stay in
    parity by rendering ONE partial. Each page supplies the rest: the form wrapper
    (events = GET + auto-submit; rule = PATCH + autosave), the tag-picker element,
    the "when" control (datepicker vs window select), and the chips row (it adds
    the when-chips after tags/_filter_chips). Only What/Where + the free-text row
    live here.

    Locals: filter (for the applied lists, so picks drop out of the dropdowns),
    id_prefix (unique combobox ids per page). The combobox names are throwaways —
    only the chips' s[]/q[]/l[] hidden fields submit. %>
<%# The What dropdown suggests the curated STYLES plus the in-use GENRES (deduped
    against the style names, minus anything already applied) — so the dropdown is a
    discovery surface for the same descriptors you tap on a row. A style pick commits
    its exact s[] bucket; a genre pick or free text commits q[] (substring). The style
    names go to the controller via data-style-names so it can route each pick. %>
<% what_styles = available_tags(context: :styles, applied: filter.style_list).to_a %>
<% style_names = what_styles.map { |tag| tag.name.downcase } %>
<% what_genres = available_tags(context: :genres, applied: filter.queries).to_a.reject { |tag| style_names.include?(tag.name.downcase) } %>
<div class="filter-field" data-tag-picker-target="whatField" data-style-names="<%= what_styles.map(&:name).to_json %>">
  <%# "What" — a style pick matches s[]; a genre pick or free text becomes q[]. %>
  <div class="input-wrapper flex flex-row gap-small"
       data-action="hw-combobox:selection->tag-picker#add"
       data-tag-picker-field-param="s[]" data-tag-picker-query-field-param="q[]">
    <%# autocomplete: :list (not the default :both) disables the inline pre-fill, so
        the input holds exactly what was typed — letting tag-picker's Enter handler
        treat a query that's a prefix of a style ("Bl") as free text rather than
        the gem hijacking it to the style ("Blues"). %>
    <%= combobox_tag "#{id_prefix}_what", combobox_options(what_styles + what_genres, render_in: { partial: 'tags/chip' }, value: :name),
          name_when_new: 'query', autocomplete: :list, placeholder: t('events.filter.what') do |combobox| %>
      <% combobox.customize_fieldset class: 'flex-grow' %>
      <%# Lead with the magnifying glass (not the styles glyph): the field's
          superpower is free-text search over acts/styles/genres. %>
      <% combobox.customize_handle class: "filter-icon #{tag_icon_class(context: 'query')}" %>
      <%# Disable the gem's own hidden field so it never submits: the picks we keep
          come through hw-combobox:selection into our s[]/q[] chips, but the gem's
          hidden field (name "#{id_prefix}_what") would otherwise serialize the
          soft-selected option into our GET URL (e.g. ?filter_what=Berner+Mundartrock).
          The gem still reads/writes its value+name in JS (disabled blocks only
          submission), so selection routing is unaffected. %>
      <% combobox.customize_hidden_field disabled: true %>
    <% end %>
  </div>

  <%# Free-text "Search for «X»" affordance. The combobox accepts free text but
      gives no hint; tag-picker#connect moves this row into the dropdown and
      reveals it when the typed text matches no style. Hidden + no filterable
      attribute, so the gem never treats it as an option. %>
  <button type="button" hidden
          class="hw-combobox__option filter-searchfor"
          data-tag-picker-target="searchFor"
          data-search-for-template="<%= t('events.filter.search_for', query: '%{query}') %>"
          data-search-anything="<%= t('events.filter.search_anything') %>"
          data-action="tag-picker#addSearchQuery">
    <span class="filter-searchfor__label" data-search-for-label></span>
  </button>
</div>

<div class="filter-field">
  <%# "Where" — locations as l[]; options carry a muted "· Kanton/Stadt/Lokal". %>
  <div class="input-wrapper flex flex-row gap-small"
       data-action="hw-combobox:selection->tag-picker#add"
       data-tag-picker-field-param="l[]">
    <%= combobox_tag "#{id_prefix}_where", combobox_options(available_tags(context: :locations, applied: filter.location_list), render_in: { partial: 'tags/location_chip' }, value: :name),
          placeholder: t('events.filter.where') do |combobox| %>
      <% combobox.customize_fieldset class: 'flex-grow' %>
      <% combobox.customize_handle class: "filter-icon #{tag_icon_class(context: 'locations')}" %>
      <%# See the What field above: disable the gem's hidden field so it doesn't
          leak "#{id_prefix}_where" into the GET URL; we submit l[] chips instead. %>
      <% combobox.customize_hidden_field disabled: true %>
    <% end %>
  </div>
</div>
