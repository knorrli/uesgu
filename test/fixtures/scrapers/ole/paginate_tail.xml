<?xml version="1.0" encoding="UTF-8"?>
<!--
  Synthetic OLE page with an UPCOMING event and NO <next_url> — the trailing page
  of an oldest-first feed. In the safety test it sits behind several past-only
  pages; the loop must page all the way through to it (its event proving present).
-->
<export>
  <meta>
    <max_pages>99</max_pages>
  </meta>
  <events>
    <event source_id="tail">
      <name>Tail Act</name>
      <url>https://venue.example/events/tail</url>
      <shows>
        <show source_id="t-1"><date_start>2026-11-11T20:00:00+01:00</date_start></show>
      </shows>
    </event>
  </events>
</export>
