<?xml version="1.0" encoding="UTF-8"?>
<!--
  Synthetic single-venue OLE feed exercising the repeated-house-blurb filter
  (REPEAT_DROP_THRESHOLD). Invented taxonomy + names (project-test-synthetic-taxonomy).
  Every event here carries a POPULATED <description> so it clears #description_present?
  — that's the leak the frequency filter is for. Three lead shapes:
    - "Echo One…Five": the same house blurb on 5 events  -> dropped (>= threshold).
    - "Glorpfest" blurb on 2 festival days               -> kept (below threshold).
    - "Wibble Trio": a unique per-event lead             -> kept.
  All shows are future relative to the suite's pinned TODAY (2026-06-10).
-->
<export>
  <meta>
    <max_pages>1</max_pages>
    <next_url></next_url>
  </meta>
  <events>
    <event source_id="echo-1">
      <name>Echo One</name>
      <url>https://venue.example/events/echo-1</url>
      <lead>Willkommen im Klangkeller, dem Ort fuer Musik seit 1987.</lead>
      <description>Real populated description one.</description>
      <shows><show source_id="echo-1-s"><date_start>2026-07-01T20:00:00+02:00</date_start></show></shows>
      <categories><category>Zorpjazz</category></categories>
      <location><name>Klangkeller Saal</name><code>3011</code><locality>Bern</locality></location>
